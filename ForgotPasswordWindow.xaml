<Window x:Class="BeiShuiCS2.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="找回密码"
        Width="480" Height="1012"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="0,0,0,30">
        <Ellipse Width="400" Height="400" Fill="{StaticResource PrimaryBrush}"
                 Opacity="0.04" HorizontalAlignment="Center" VerticalAlignment="Top"
                 Margin="0,-100,0,0"/>

        <Grid Margin="48,40,48,48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 关闭按钮 -->
            <Button Grid.Row="0" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Click="Close_Click"/>

            <!-- 标题 -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,32">
                <TextBlock Text="&#xE785;" FontFamily="Segoe Fluent Icons"
                           FontSize="40" Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="找回密码" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="输入你的注册邮箱，我们会发送重置链接" FontSize="13"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 步骤指示 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,0,0,24">
                <StackPanel HorizontalAlignment="Center">
                    <Border x:Name="step1Dot" Width="32" Height="32" CornerRadius="16"
                            Background="{StaticResource PrimaryBrush}">
                        <TextBlock Text="1" FontSize="14" FontWeight="Bold"
                                   Foreground="#0A0A0A" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="验证邮箱" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Width="60" Height="2" Background="{StaticResource BorderPrimaryBrush}"
                        VerticalAlignment="Center" Margin="12,0"/>
                <StackPanel HorizontalAlignment="Center">
                    <Border x:Name="step2Dot" Width="32" Height="32" CornerRadius="16"
                            Background="{StaticResource BorderPrimaryBrush}">
                        <TextBlock Text="2" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="设置新密码" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Width="60" Height="2" Background="{StaticResource BorderPrimaryBrush}"
                        VerticalAlignment="Center" Margin="12,0"/>
                <StackPanel HorizontalAlignment="Center">
                    <Border x:Name="step3Dot" Width="32" Height="32" CornerRadius="16"
                            Background="{StaticResource BorderPrimaryBrush}">
                        <TextBlock Text="3" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="完成" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- 表单（步骤1：输入邮箱验证码） -->
            <StackPanel x:Name="step1Panel" Grid.Row="2" Margin="0,8,0,0">
                <TextBlock Text="邮箱地址" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="txtEmail" Style="{StaticResource TxtInput}" Margin="0,0,0,16" Height="73"/>

                <TextBlock Text="验证码" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtCode" Style="{StaticResource TxtInput}"
                             MaxLength="6" Grid.Column="0"/>
                    <Button x:Name="btnSendCode" Grid.Column="1" Content="发送验证码"
                            Style="{StaticResource BtnGhost}" Margin="12,0,0,0"
                            Width="110" Click="SendCode_Click"/>
                </Grid>

                <!-- 步骤2：设置新密码（初始隐藏） -->
                <StackPanel x:Name="step2Panel" Visibility="Collapsed">
                    <TextBlock Text="新密码" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="txtNewPassword" Style="{StaticResource PwdInput}"
                                 Margin="0,0,0,16"/>

                    <TextBlock Text="确认新密码" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="txtConfirmPassword" Style="{StaticResource PwdInput}"
                                 Margin="0,0,0,16"/>
                </StackPanel>

                <!-- 错误提示 -->
                <TextBlock x:Name="txtError" Foreground="#F43F5E" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed"/>

                <Button x:Name="btnSubmit" Content="下一步"
                        Style="{StaticResource BtnPrimary}"
                        Height="50" FontSize="16"
                        Click="BtnSubmit_Click"/>
            </StackPanel>

            <!-- 返回登录 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,16,0,0">
                <TextBlock Text="想起密码了？" FontSize="13"
                           Foreground="{StaticResource TextMutedBrush}"/>
                <Button Content="返回登录" Style="{StaticResource BtnLink}"
                        Click="GoLogin_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
