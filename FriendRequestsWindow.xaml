<Window x:Class="BeiShuiCS2.FriendRequestsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="好友请求"
        Width="460" Height="525"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="24" Background="#FF0A1A10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="3"/>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,16">
            <Border Width="48" Height="48" CornerRadius="24"
                    Background="{StaticResource PrimaryGradientBrush}"
                    HorizontalAlignment="Center" Margin="0,0,0,10">
                <TextBlock Text="&#xE716;" FontFamily="Segoe Fluent Icons"
                           FontSize="22" Foreground="{StaticResource BgDeepBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="好友请求" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="requestsPanel"/>
        </ScrollViewer>

        <Button Grid.Row="2" Content="关闭"
                Style="{StaticResource BtnNeumorph}"
                Width="120" FontSize="14"
                HorizontalAlignment="Center" Margin="0,5,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>
