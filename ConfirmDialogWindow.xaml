<Window x:Class="BeiShuiCS2.ConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认"
        Width="440" Height="262"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"/>

        <!-- 标题栏 -->
        <Grid Height="48" VerticalAlignment="Top" Margin="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="8"
                    Background="#2A1F1F" Margin="0,0,8,0">
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons"
                           FontSize="14" Foreground="#FB7185"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="txtTitle" Grid.Column="1" Text="确认操作"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="2" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    Click="Cancel_Click" VerticalAlignment="Center"/>
        </Grid>

        <!-- 消息 -->
        <TextBlock x:Name="txtMessage" Text=""
                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   Margin="24,64,24,0"/>

        <!-- 按钮 -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,24,20">
            <Button x:Name="btnCancel" Content="取消" Style="{StaticResource BtnGhost}"
                    MinWidth="90" Height="43" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button x:Name="btnConfirm" Content="确认删除" Style="{StaticResource BtnDanger}"
                    MinWidth="110" Height="43" Click="Confirm_Click">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="0"
                                      Opacity="0.3" Color="#FB7185"/>
                </Button.Effect>
            </Button>
        </StackPanel>
    </Grid>
</Window>
