<Window x:Class="BeiShuiCS2.SteamBindWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam 账号未绑定"
        Width="480" Height="689"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="32" Background="#FF0A1A10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="3"/>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Border Width="64" Height="64" CornerRadius="32"
                    Background="{StaticResource DangerGradientBrush}"
                    HorizontalAlignment="Center" Margin="0,0,0,12"
                    RenderTransformOrigin="0.5,0.5">
                <TextBlock Text="!" FontSize="32" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Steam 账号未绑定" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource WarningBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="此 Steam 账号尚未关联背水对战平台账户" FontSize="13"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Border CornerRadius="{StaticResource RadiusMedium}"
                    Background="{StaticResource BgElevatedBrush}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                    BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Background="{StaticResource PrimaryGradientBrush}" Margin="0,0,12,0">
                            <TextBlock Text="1" FontSize="16" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="注册新账号" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="创建背水账号并绑定此 Steam" FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button x:Name="btnRegister" Content="去注册并绑定"
                            Style="{StaticResource BtnGradient}"
                            Height="44" FontSize="14"
                            Click="Register_Click"/>
                </StackPanel>
            </Border>

            <Border CornerRadius="{StaticResource RadiusMedium}"
                    Background="{StaticResource BgElevatedBrush}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                    BorderThickness="1" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Background="{StaticResource AccentTealBrush}" Margin="0,0,12,0">
                            <TextBlock Text="2" FontSize="16" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="已有账号" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="登录后在设置中绑定 Steam" FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button x:Name="btnLogin" Content="去登录"
                            Style="{StaticResource BtnPrimary}"
                            Height="44" FontSize="14"
                            Click="Login_Click"/>
                </StackPanel>
            </Border>

            <TextBlock x:Name="txtSteamId" Text=""
                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0,16,0,0"/>
        </StackPanel>

        <Button Grid.Row="1" Content="取消"
                Style="{StaticResource BtnNeumorph}"
                Width="120" FontSize="14"
                HorizontalAlignment="Center" Click="Cancel_Click" Margin="0,436,0,0" Grid.RowSpan="2"/>
    </Grid>
</Window>
