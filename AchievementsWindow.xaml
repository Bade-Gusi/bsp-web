<Window x:Class="BeiShuiCS2.AchievementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="成就系统" 
        Width="800" Height="700"
        WindowStartupLocation="CenterOwner"
        MinWidth="600" MinHeight="500" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <!-- 成就卡片样式 -->
        <Style x:Key="AchievementCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardGradientBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="Unlocked">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"/>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Height="64" Margin="32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE9D2;" FontFamily="Segoe Fluent Icons"
                           FontSize="28" Foreground="{StaticResource WarningBrush}"
                           Margin="0,0,16,0"/>
                <StackPanel>
                    <TextBlock Text="成就系统" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="txtProgress" Text="已解锁 5 / 20"
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    Click="Close_Click"/>
        </Grid>

        <!-- 进度条 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="32,0,32,16" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="总进度" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="txtPercent" Text="25%"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="12,0,0,0"/>
                </StackPanel>
                <Border Grid.Row="1" Background="{StaticResource BgElevatedBrush}"
                        CornerRadius="{StaticResource RadiusFull}" Height="8">
                    <Border x:Name="progressBar" Background="{StaticResource PrimaryGradientBrush}"
                            CornerRadius="{StaticResource RadiusFull}" Width="0"
                            HorizontalAlignment="Left">
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         From="0" To="200" Duration="0:0:1"
                                                         EasingFunction="{StaticResource EaseOutCubic}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <!-- 成就列表 -->
        <ScrollViewer Grid.Row="2" Margin="32,0,32,32"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="achievementsPanel">
                <!-- 动态生成 -->
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
