<Window x:Class="BeiShuiCS2.RoomDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:e="clr-namespace:BeiShuiCS2"
        Title="房间详情" 
        Width="700" Height="669"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">


    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="4"/>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock x:Name="txtRoomName" Text="房间名称"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock x:Name="txtMap" Text="de_dust2"
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="{StaticResource FontMono}"/>
                    <TextBlock Text=" · " FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="8,0"/>
                    <TextBlock x:Name="txtServer" Text="CN"
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    Click="Close_Click"/>
        </Grid>

        <!-- IP信息 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="服务器地址" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="txtIP" Text="127.0.0.1:27015"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,4,0,0"
                               FontFamily="{StaticResource FontMono}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="&#xE8C8; 复制"
                        Style="{StaticResource BtnGhost}"
                        Width="100" Height="48"
                        VerticalAlignment="Center"
                        Click="CopyIP_Click"/>
            </Grid>
        </Border>

        <!-- 玩家列表 -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="玩家列表" Style="{StaticResource PageSubHeader}"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="playersPanel">
                        <!-- 动态生成玩家 -->
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,24,0,0">
            <Button x:Name="btnInvite" Content="&#xE716; 邀请好友"
                    Style="{StaticResource BtnGhost}"
                    Width="140" Height="48" FontSize="14"
                    Margin="0,0,12,0" Click="Invite_Click"/>
            <Button x:Name="btnStart" Content="&#xE768; 开始游戏"
                    Style="{StaticResource BtnPrimary}"
                    Width="160" Height="48" FontSize="16"
                    Click="StartGame_Click">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                      Opacity="0.4" Color="#4ADE80"/>
                </Button.Effect>
            </Button>
        </StackPanel>
    </Grid>
</Window>

