<Window x:Class="BeiShuiCS2.ServerAuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="服务器设置"
        Width="572" Height="531"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="3"/>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons"
                       FontSize="36" Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="连接服务器" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,4"/>
            <TextBlock Text="请输入服务器地址和端口以连接到背水对战平台"
                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- 表单 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <!-- 服务器地址 -->
            <TextBlock Text="服务器地址" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <Border Background="{StaticResource BgElevatedBrush}"
                    CornerRadius="{StaticResource RadiusSmall}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                    BorderThickness="1" Padding="12,10" Margin="0,0,0,16">
                <TextBox x:Name="txtServerUrl" Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="14" Text="hni1.wch1.top"
                         CaretBrush="{StaticResource PrimaryBrush}"/>
            </Border>

            <!-- 端口 -->
            <TextBlock Text="端口" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <Border Background="{StaticResource BgElevatedBrush}"
                    CornerRadius="{StaticResource RadiusSmall}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                    BorderThickness="1" Padding="12,10" Margin="0,0,0,20">
                <TextBox x:Name="txtPort" Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="14" Text="5000"
                         CaretBrush="{StaticResource PrimaryBrush}"/>
            </Border>

            <!-- 使用 HTTPS -->
            <CheckBox x:Name="chkUseHttps" Content="使用 HTTPS"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      FontSize="13" IsChecked="True" Margin="0,0,0,20"/>

            <!-- 连接状态 -->
            <Border x:Name="statusPanel" Visibility="Collapsed"
                    CornerRadius="{StaticResource RadiusSmall}" Padding="12,8"
                    Margin="0,0,0,0">
                <TextBlock x:Name="txtStatus" Text="" FontSize="12"
                           HorizontalAlignment="Center"/>
            </Border>
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,16,0,0">
            <Button x:Name="btnTest" Content="&#xE9CE; 测试连接"
                    Style="{StaticResource BtnNeumorph}"
                    Width="140" Height="49" FontSize="14"
                    Margin="0,0,12,0" Click="Test_Click"/>
            <Button x:Name="btnSave" Content="&#xE8FB; 保存并连接"
                    Style="{StaticResource BtnPrimary}"
                    Width="160" Height="48" FontSize="14"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
