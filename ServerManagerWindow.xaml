<Window x:Class="BeiShuiCS2.ServerManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理中心"
        Width="740" Height="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_Loaded" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <!-- 服务器条目卡片样式 -->
        <Style x:Key="ServerItemCard" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 标签按钮样式（独立模板，不依赖 BtnGhost） -->
        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A3A28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 操作按钮组样式（内置圆角） -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusMedium}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 浮动粒子层 -->
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"/>

        <!-- 装饰光晕 -->
        <Ellipse Width="300" Height="300"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-120,-100,0,0"
                 Fill="{StaticResource PrimaryBrush}" Opacity="0.03"
                 IsHitTestVisible="False"/>
        <Ellipse Width="200" Height="200"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-60,-60"
                 Fill="{StaticResource AccentTealBrush}" Opacity="0.02"
                 IsHitTestVisible="False"/>

        <Grid x:Name="contentRoot" Margin="28,28,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════ 标题栏 ═══════ -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo 图标 -->
                <Border x:Name="headerIcon" Grid.Column="0" Width="44" Height="44"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Background="{StaticResource PrimaryGradientBrush}"
                        Margin="0,0,14,0"
                        RenderTransformOrigin="0.5,0.5">
                    <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons"
                               FontSize="22" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- 标题区域 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="txtTitle" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="txtSubtitle" Text="游戏服务器与本地数据管理"
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource WindowControlBtn}"
                        x:Name="btnClose"
                        Click="Close_Click"
                        RenderTransformOrigin="0.5,0.5">
                </Button>
            </Grid>

            <!-- ═══════ Tab 切换栏 ═══════ -->
            <Border x:Name="tabBar" Grid.Row="1"
                    Background="{StaticResource BgElevatedBrush}"
                    CornerRadius="{StaticResource RadiusMedium}"
                    Padding="4" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="tabCol1" Width="*"/>
                        <ColumnDefinition x:Name="tabCol2" Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="tabServers" Grid.Column="0" Content="&#xE774;  游戏服务器"
                            Style="{StaticResource TabBtn}" Click="TabServers_Click"
                            Background="{StaticResource PrimaryGradientBrush}" Foreground="White"/>
                    <Button x:Name="tabData" Grid.Column="1" Content="&#xE8B7;  本地数据"
                            Style="{StaticResource TabBtn}" Click="TabData_Click"
                            Background="#152A1C" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <!-- 激活标签底部指示条 -->
                    <Border x:Name="tabIndicator" Height="3" Width="0"
                            HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Background="{StaticResource PrimaryGradientBrush}"
                            CornerRadius="2" Margin="8,0"
                            IsHitTestVisible="False">
                        <Border.RenderTransform>
                            <TranslateTransform X="0" Y="0"/>
                        </Border.RenderTransform>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════ Tab 1: 游戏服务器 ═══════ -->
            <Grid x:Name="panelServers" Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 服务器列表卡片 -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 列表表头 -->
                        <Border x:Name="listHeader" Grid.Row="0"
                                Background="{StaticResource BgElevatedBrush}"
                                Padding="16,12"
                                CornerRadius="{StaticResource RadiusMedium}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="名称" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="服务器地址" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="状态" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="4,4,4,4">
                            <StackPanel x:Name="serverListPanel"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- 操作按钮组 -->
                <StackPanel x:Name="actionBtnPanel" Grid.Row="1"
                            Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,14,0,0">
                    <Button x:Name="btnAdd" Content="&#xE710;  添加" Style="{StaticResource ActionBtn}"
                            Background="{StaticResource PrimaryGradientBrush}" Foreground="White"
                            BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0"
                            Click="AddServer_Click"
                            Margin="0,0,8,0" Width="95">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.2" Color="{StaticResource PrimaryColor}"/>
                        </Button.Effect>
                    </Button>
                    <Button x:Name="btnEdit" Content="&#xE70F;  修改" Style="{StaticResource ActionBtn}"
                            Background="{StaticResource BgElevatedBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderPrimaryBrush}" BorderThickness="1"
                            Click="EditServer_Click"
                            Margin="0,0,8,0" Width="95"/>
                    <Button x:Name="btnDelete" Content="&#xE74D;  删除" Style="{StaticResource ActionBtn}"
                            Background="{StaticResource BgElevatedBrush}" Foreground="{StaticResource DangerBrush}"
                            BorderBrush="{StaticResource DangerBrush}" BorderThickness="1"
                            Click="DeleteServer_Click"
                            Margin="0,0,8,0" Width="95"/>
                    <Button x:Name="btnConnect" Content="&#xE8FB;  连接" Style="{StaticResource ActionBtn}"
                            Background="{StaticResource PrimaryGradientBrush}" Foreground="White"
                            BorderThickness="0"
                            Click="ConnectServer_Click" Width="95">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.3" Color="{StaticResource PrimaryColor}"/>
                        </Button.Effect>
                    </Button>
                </StackPanel>

                <!-- 当前选择条 -->
                <Border x:Name="selectionBar" Grid.Row="2"
                        Background="{StaticResource BgElevatedBrush}"
                        CornerRadius="{StaticResource RadiusMedium}"
                        BorderBrush="{StaticResource BorderPrimaryBrush}"
                        BorderThickness="1" Padding="16,12"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE896;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="14" Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" Text="当前选择:" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtSelectedIP" Grid.Column="2" Text="未选择"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontFamily="{StaticResource FontMono}"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- 启动大按钮 -->
                <Border x:Name="launchBtnWrapper" Grid.Row="3" Margin="0,14,0,0"
                        RenderTransformOrigin="0.5,0.5">
                    <Button x:Name="btnLaunchCS2" Content="&#xE768;  启动 CS2 并自动连接"
                            Style="{StaticResource ActionBtn}" FontSize="16"
                            Background="{StaticResource PrimaryGradientBrush}"
                            Foreground="White" BorderThickness="0"
                            Height="54"
                            Click="ConnectServer_Click">
                        <Button.Effect>
                            <DropShadowEffect x:Name="launchGlow" BlurRadius="24"
                                              ShadowDepth="0" Opacity="0.4"
                                              Color="{StaticResource PrimaryColor}"/>
                        </Button.Effect>
                    </Button>
                </Border>
            </Grid>

            <!-- ═══════ Tab 2: 本地数据 ═══════ -->
            <Grid x:Name="panelData" Grid.Row="2" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- CS2 截图卡片 -->
                <Border x:Name="cardScreenshots" Grid.Row="0"
                        Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                        RenderTransformOrigin="0.5,0.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40"
                                CornerRadius="{StaticResource RadiusSmall}"
                                Background="{StaticResource BgElevatedBrush}"
                                Margin="0,0,14,0">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe Fluent Icons"
                                       FontSize="20" Foreground="{StaticResource InfoBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="CS2 游戏截图" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0">
                                <Run Text="路径:"/>
                                <Run x:Name="txtScreenshotPath" Text="自动检测中..."
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="&#xE8A7;  打开" Style="{StaticResource BtnGhost}"
                                    Width="80" Height="36" Margin="0,0,8,0"
                                    Click="OpenScreenshotFolder_Click"/>
                            <Button Content="&#xE74D;  清理" Style="{StaticResource BtnDanger}"
                                    Width="80" Height="36" Click="CleanScreenshots_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Demo 录像卡片 -->
                <Border x:Name="cardDemos" Grid.Row="1"
                        Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                        RenderTransformOrigin="0.5,0.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40"
                                CornerRadius="{StaticResource RadiusSmall}"
                                Background="{StaticResource BgElevatedBrush}"
                                Margin="0,0,14,0">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons"
                                       FontSize="20" Foreground="{StaticResource AccentTealBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="CS2 Demo 录像" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0">
                                <Run Text="路径:"/>
                                <Run x:Name="txtDemoPath" Text="自动检测中..."
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2" Content="&#xE8A7;  打开" Style="{StaticResource BtnGhost}"
                                Width="80" Height="36" Click="OpenDemoFolder_Click"/>
                    </Grid>
                </Border>

                <!-- 缓存管理卡片 -->
                <Border x:Name="cardCache" Grid.Row="2"
                        Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                        RenderTransformOrigin="0.5,0.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40"
                                CornerRadius="{StaticResource RadiusSmall}"
                                Background="{StaticResource BgElevatedBrush}"
                                Margin="0,0,14,0">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons"
                                       FontSize="20" Foreground="{StaticResource WarningBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="本地缓存" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="txtCacheSize" Text="计算中..." FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="&#xE72C;  清理" Style="{StaticResource BtnDanger}"
                                    Width="85" Height="36" Margin="0,0,8,0" Click="CleanCache_Click"/>
                            <Button Content="&#xE898;  导出" Style="{StaticResource BtnGhost}"
                                    Width="80" Height="36" Click="ExportData_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 磁盘用量卡片 -->
                <Border x:Name="cardDisk" Grid.Row="3"
                        Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                        RenderTransformOrigin="0.5,0.5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40"
                                    CornerRadius="{StaticResource RadiusSmall}"
                                    Background="{StaticResource BgElevatedBrush}"
                                    Margin="0,0,14,0">
                                <TextBlock Text="&#xE790;" FontFamily="Segoe Fluent Icons"
                                           FontSize="20" Foreground="{StaticResource PrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="磁盘用量" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource BgElevatedBrush}"
                                    CornerRadius="{StaticResource RadiusSmall}" Height="10"
                                    Margin="0,0,16,0">
                                <Border x:Name="diskUsageBar"
                                        Background="{StaticResource PrimaryGradientBrush}"
                                        CornerRadius="{StaticResource RadiusSmall}"
                                        Width="0" HorizontalAlignment="Left">
                                    <Border.Clip>
                                        <RectangleGeometry Rect="0,0,0,10"/>
                                    </Border.Clip>
                                </Border>
                            </Border>
                            <TextBlock x:Name="txtDiskUsage" Grid.Column="1"
                                       Text="0 MB / 0 MB" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 底部提示 -->
                <Border x:Name="tipFooter" Grid.Row="4"
                        Background="{StaticResource BgElevatedBrush}"
                        CornerRadius="{StaticResource RadiusMedium}" Padding="16,12">
                    <TextBlock x:Name="txtTip" Text="提示：本地数据管理功能帮助你快速访问 CS2 截图和 Demo 录像目录，清理缓存可以释放磁盘空间。"
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
