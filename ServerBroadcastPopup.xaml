<Window x:Class="BeiShuiCS2.ServerBroadcastPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="服务器广播" Width="380" Height="220"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid>
        <Border Style="{StaticResource GlassCardPremium}" Margin="16">
            <StackPanel Margin="16">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="管理员发布新服务器" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>

                <TextBlock Text="服务器地址" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock x:Name="txtServerAddress" Text="" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" FontFamily="{StaticResource FontMono}"
                           Margin="0,4,0,16"/>

                <TextBlock x:Name="txtInfo" Text="" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,16"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="btnConnect" Content="连接服务器"
                            Style="{StaticResource BtnPrimary}" Height="36" FontSize="12"
                            Click="BtnConnect_Click"/>
                    <Button Grid.Column="1" x:Name="btnCopy" Content="复制地址"
                            Style="{StaticResource BtnGhost}" Height="36" FontSize="12"
                            Margin="8,0,0,0"
                            Click="BtnCopy_Click"/>
                    <Button Grid.Column="2" x:Name="btnClose" Content="&#xE8BB;"
                            FontFamily="Segoe Fluent Icons"
                            Style="{StaticResource WindowControlBtn}"
                            Margin="8,0,0,0"
                            Click="BtnClose_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
