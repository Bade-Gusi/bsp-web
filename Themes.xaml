                                             EasingFunction="{StaticResource EaseOutCubic}"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.01" Duration="0:0:0.25"
                                             EasingFunction="{StaticResource EaseOutCubic}"/>
                            <ColorAnimation Storyboard.TargetProperty="BorderBrush.Color" To="{StaticResource PrimaryColor}" Duration="0:0:0.25"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
