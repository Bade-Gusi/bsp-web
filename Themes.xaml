<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================ -->
    <!-- 背水对战平台 (Aurora Nova) - 全局主题资源字典                  -->
    <!-- 设计系统: Midnight Tech / 翠绿亮色 / 8px 网格 / 统一样式      -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- 1. 色彩系统 (Midnight Nova - 暗夜新星)                      -->
    <!--    主色 #22D97E 翠绿 / 辅色青 #06D8A0 / 紫 #A855F7          -->
    <!--    背景采用深炭灰，层次分明，由深到浅 5 层                    -->
    <!-- ============================================================ -->

    <!-- === 1a. 品牌色（高饱和，在深色背景上强烈突出） === -->
    <Color x:Key="PrimaryColor">#22D97E</Color>
    <Color x:Key="PrimaryGlowColor">#10B981</Color>
    <Color x:Key="AccentColor">#22D97E</Color>
    <Color x:Key="AccentTealColor">#06D8A0</Color>
    <Color x:Key="AccentPurpleColor">#A855F7</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>

    <!-- === 1b. 暗色背景（5层深度层次，中性深灰，告别全绿） === -->
    <Color x:Key="BgDeepColor">#0B0E0F</Color>
    <Color x:Key="BgCardColor">#14181A</Color>
    <Color x:Key="BgElevatedColor">#1C2123</Color>
    <Color x:Key="BgHoverColor">#262D30</Color>
    <Color x:Key="BgOverlayColor">#080A0B</Color>

    <!-- === 1c. 暗色文字 === -->
    <Color x:Key="TextPrimaryColor">#F2F5F3</Color>
    <Color x:Key="TextSecondaryColor">#C0CCBF</Color>
    <Color x:Key="TextMutedColor">#808C86</Color>

    <!-- === 1d. 暗色边框 === -->
    <Color x:Key="BorderPrimaryColor">#2A3330</Color>
    <Color x:Key="BorderFocusedColor">#22D97E</Color>

    <!-- === 1e. 亮色主题（保留不动） === -->
    <Color x:Key="LightPrimaryColor">#059669</Color>
    <Color x:Key="LightPrimaryGlowColor">#10B981</Color>
    <Color x:Key="LightAccentColor">#0D9488</Color>
    <Color x:Key="LightDangerColor">#DC2626</Color>
    <Color x:Key="LightWarningColor">#D97706</Color>
    <Color x:Key="LightInfoColor">#2563EB</Color>
    <Color x:Key="LightBgDeepColor">#F0F2F0</Color>
    <Color x:Key="LightBgCardColor">#FFFFFF</Color>
    <Color x:Key="LightBgElevatedColor">#FAFAFA</Color>
    <Color x:Key="LightBgHoverColor">#E2E8E2</Color>
    <Color x:Key="LightTextPrimaryColor">#0F1A12</Color>
    <Color x:Key="LightTextSecondaryColor">#5A6B62</Color>
    <Color x:Key="LightTextMutedColor">#94A39B</Color>
    <Color x:Key="LightBorderPrimaryColor">#D0D8D3</Color>

    <!-- ============================================================ -->
    <!-- 2. 间距系统 (8px 网格)                                        -->
    <!-- ============================================================ -->
    <Thickness x:Key="Space4">4,4,4,4</Thickness>
    <Thickness x:Key="Space8">8,8,8,8</Thickness>
    <Thickness x:Key="Space12">12,12,12,12</Thickness>
    <Thickness x:Key="Space16">16,16,16,16</Thickness>
    <Thickness x:Key="Space20">20,20,20,20</Thickness>
    <Thickness x:Key="Space24">24,24,24,24</Thickness>
    <Thickness x:Key="Space32">32,32,32,32</Thickness>

    <!-- ============================================================ -->
    <!-- 3. 圆角系统                                                   -->
    <!-- ============================================================ -->
    <CornerRadius x:Key="RadiusSmall">8</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">12</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">16</CornerRadius>
    <CornerRadius x:Key="RadiusXLarge">24</CornerRadius>
    <CornerRadius x:Key="RadiusFull">999</CornerRadius>

    <!-- ============================================================ -->
    <!-- 4. 阴影系统                                                   -->
    <!-- ============================================================ -->
    <DropShadowEffect x:Key="ShadowSmall" BlurRadius="8"   ShadowDepth="2" Opacity="0.35"  Color="#000000"/>
    <DropShadowEffect x:Key="ShadowMedium" BlurRadius="20" ShadowDepth="4" Opacity="0.45"  Color="#000000"/>
    <DropShadowEffect x:Key="ShadowLarge" BlurRadius="40" ShadowDepth="8" Opacity="0.55"  Color="#000000"/>
    <DropShadowEffect x:Key="ShadowGlow" BlurRadius="24" ShadowDepth="0" Color="#22D97E" Opacity="0.35"/>
    <DropShadowEffect x:Key="ShadowGlowTeal" BlurRadius="24" ShadowDepth="0" Color="#06D8A0" Opacity="0.25"/>
    <DropShadowEffect x:Key="ShadowGlowPurple" BlurRadius="24" ShadowDepth="0" Color="#A855F7" Opacity="0.25"/>
    <DropShadowEffect x:Key="ShadowGlowDanger" BlurRadius="24" ShadowDepth="0" Color="#EF4444" Opacity="0.3"/>

    <!-- ============================================================ -->
    <!-- 5. 缓动函数（保持不变）                                       -->
    <!-- ============================================================ -->
    <CubicEase x:Key="EaseOutCubic" EasingMode="EaseOut"/>
    <CubicEase x:Key="EaseInOutCubic" EasingMode="EaseInOut"/>
    <QuarticEase x:Key="EaseOutQuart" EasingMode="EaseOut"/>
    <BackEase x:Key="EaseOutBack" EasingMode="EaseOut" Amplitude="0.3"/>
    <ElasticEase x:Key="EaseOutElastic" EasingMode="EaseOut" Oscillations="1" Springiness="3"/>
    <ExponentialEase x:Key="EaseOutExpo" EasingMode="EaseOut" Exponent="6"/>

    <!-- ============================================================ -->
    <!-- 6. 字体系统（保持不变）                                       -->
    <!-- ============================================================ -->
    <FontFamily x:Key="FontPrimary">Microsoft YaHei, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="FontMono">JetBrains Mono, Cascadia Code, Consolas, monospace</FontFamily>

    <!-- ============================================================ -->
    <!-- 7. 动态画刷                                                   -->
    <!-- ============================================================ -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="{StaticResource PrimaryGlowColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentTealBrush" Color="{StaticResource AccentTealColor}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurpleColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevatedColor}"/>
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHoverColor}"/>
    <SolidColorBrush x:Key="BgOverlayBrush" Color="{StaticResource BgOverlayColor}" Opacity="0.85"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderPrimaryBrush" Color="{StaticResource BorderPrimaryColor}"/>
    <SolidColorBrush x:Key="BorderFocusedBrush" Color="{StaticResource BorderFocusedColor}"/>

    <!-- ============================================================ -->
    <!-- 8. 渐变画刷                                                   -->
    <!-- ============================================================ -->

    <!-- 背景渐变：深炭灰到黑 -->
    <LinearGradientBrush x:Key="BgGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0E1214" Offset="0"/>
        <GradientStop Color="#0B0E0F" Offset="0.3"/>
        <GradientStop Color="#090C0D" Offset="0.6"/>
        <GradientStop Color="#07090A" Offset="1"/>
    </LinearGradientBrush>

    <!-- 主色渐变：翠绿到青 -->
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#22D97E" Offset="0"/>
        <GradientStop Color="#06D8A0" Offset="1"/>
    </LinearGradientBrush>

    <!-- 三色极光渐变 -->
    <LinearGradientBrush x:Key="AuroraGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#22D97E" Offset="0"/>
        <GradientStop Color="#06D8A0" Offset="0.5"/>
        <GradientStop Color="#A855F7" Offset="1"/>
    </LinearGradientBrush>

    <!-- 卡片渐变 -->
    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#181E20" Offset="0"/>
        <GradientStop Color="#14181A" Offset="1"/>
    </LinearGradientBrush>

    <!-- 悬浮卡片渐变 -->
    <LinearGradientBrush x:Key="ElevatedGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#202628" Offset="0"/>
        <GradientStop Color="#1C2123" Offset="1"/>
    </LinearGradientBrush>

    <!-- 玻璃质感渐变 -->
    <LinearGradientBrush x:Key="GlassGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1C212355" Offset="0"/>
        <GradientStop Color="#14181A44" Offset="1"/>
    </LinearGradientBrush>

    <!-- 危险渐变 -->
    <LinearGradientBrush x:Key="DangerGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#EF4444" Offset="0"/>
        <GradientStop Color="#DC2626" Offset="1"/>
    </LinearGradientBrush>

    <!-- 翠绿高亮渐变（按钮/标签用） -->
    <LinearGradientBrush x:Key="GreenHighlightBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A3D2A" Offset="0"/>
        <GradientStop Color="#0F2A1E" Offset="1"/>
    </LinearGradientBrush>

    <!-- ============================================================ -->
    <!-- 9. 窗口入场动画 Storyboard（保持不变）                        -->
    <!-- ============================================================ -->
    <Storyboard x:Key="WindowFadeIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.4"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="WindowScaleIn">
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                         From="0.95" To="1" Duration="0:0:0.4"
                         EasingFunction="{StaticResource EaseOutBack}"/>
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                         From="0.95" To="1" Duration="0:0:0.4"
                         EasingFunction="{StaticResource EaseOutBack}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.35"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="FadeIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.4"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="FadeOut">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="1" To="0" Duration="0:0:0.3"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="ScaleIn">
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                         From="0.9" To="1" Duration="0:0:0.4"
                         EasingFunction="{StaticResource EaseOutBack}"/>
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                         From="0.9" To="1" Duration="0:0:0.4"
                         EasingFunction="{StaticResource EaseOutBack}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.3"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="SlideInRight">
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                         From="100" To="0" Duration="0:0:0.5"
                         EasingFunction="{StaticResource EaseOutBack}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.3"/>
    </Storyboard>
    <Storyboard x:Key="SlideInUp">
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                         From="50" To="0" Duration="0:0:0.5"
                         EasingFunction="{StaticResource EaseOutBack}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.3"/>
    </Storyboard>
    <Storyboard x:Key="BounceBadge">
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                         From="0" To="1.2" Duration="0:0:0.3"
                         EasingFunction="{StaticResource EaseOutBack}"/>
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                         From="0" To="1.2" Duration="0:0:0.3"
                         EasingFunction="{StaticResource EaseOutBack}"/>
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                         From="1.2" To="1" BeginTime="0:0:0.3" Duration="0:0:0.2"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                         From="1.2" To="1" BeginTime="0:0:0.3" Duration="0:0:0.2"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="PulseScale" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                         From="1" To="1.1" Duration="0:0:1" AutoReverse="True"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                         From="1" To="1.1" Duration="0:0:1" AutoReverse="True"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="VSPulse" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.6" To="1" Duration="0:0:1.2" AutoReverse="True"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" From="1" To="1.05" Duration="0:0:1.2" AutoReverse="True"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" From="1" To="1.05" Duration="0:0:1.2" AutoReverse="True"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="PlayerEnter">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                         From="-30" To="0" Duration="0:0:0.5"
                         EasingFunction="{StaticResource EaseOutBack}"/>
    </Storyboard>
    <Storyboard x:Key="RingRotate" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                         From="0" To="360" Duration="0:0:2"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="GlowPulse" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="Effect.Opacity" From="0.3" To="0.7" Duration="0:0:2" AutoReverse="True"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="Effect.BlurRadius" From="16" To="28" Duration="0:0:2" AutoReverse="True"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="Shimmer" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="0.7" Duration="0:0:1.2" AutoReverse="True"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="SlideInUpStagger">
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                         From="30" To="0" Duration="0:0:0.5"
                         EasingFunction="{StaticResource EaseOutBack}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="FadeScaleIn">
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.4"
                         EasingFunction="{StaticResource EaseOutBack}"/>
        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.4"
                         EasingFunction="{StaticResource EaseOutBack}"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"
                         EasingFunction="{StaticResource EaseOutCubic}"/>
    </Storyboard>
    <Storyboard x:Key="AuroraDrift" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.4" To="0.8" Duration="0:0:3" AutoReverse="True"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                         From="-10" To="10" Duration="0:0:4" AutoReverse="True"
                         EasingFunction="{StaticResource EaseInOutCubic}"/>
    </Storyboard>

    <!-- ============================================================ -->
    <!-- 10. 按钮样式 ★★★ 核心重写 ★★★                              -->
    <!-- ============================================================ -->

    <!-- ──────────────────────────────────── -->
    <!-- BtnPrimary - 主要行动按钮（强化版）  -->
    <!-- ──────────────────────────────────── -->
    <Style x:Key="BtnPrimary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryGradientBrush}"/>
        <Setter Property="Foreground" Value="#0A1510"/>
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="24,14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#22D97E" Opacity="0.35"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusMedium}" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="False"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0.88" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#22D97E" Opacity="0.55"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.78"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ──────────────────────────────────── -->
    <!-- BtnGlow - 带呼吸光晕（基于BtnPrimary）-->
    <!-- ──────────────────────────────────── -->
    <Style x:Key="BtnGlow" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="#22D97E" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ──────────────────────────────────── -->
    <!-- BtnPrimaryGlow - 呼吸光晕脉动       -->
    <!-- ──────────────────────────────────── -->
    <Style x:Key="BtnPrimaryGlow" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#22D97E" Opacity="0.4"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard x:Name="glowPulse" RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="Effect.Opacity"
                                             From="0.3" To="0.7" Duration="0:0:2" AutoReverse="True"
                                             EasingFunction="{StaticResource EaseInOutCubic}"/>
                            <DoubleAnimation Storyboard.TargetProperty="Effect.BlurRadius"
                                             From="16" To="28" Duration="0:0:2" AutoReverse="True"
                                             EasingFunction="{StaticResource EaseInOutCubic}"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ──────────────────────────────────── -->
    <!-- BtnSecondary - 次要按钮（新增！）    -->
    <!-- 视觉重量介于 Primary 和 Ghost 之间  -->
    <!-- ──────────────────────────────────── -->
    <Style x:Key="BtnSecondary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GreenHighlightBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusMedium}" Padding="{TemplateBinding Padding}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="False"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1.03" Duration="0:0:0.2"
                                                         EasingFunction="{StaticResource EaseOutBack}"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1.03" Duration="0:0:0.2"
                                                         EasingFunction="{StaticResource EaseOutBack}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1" Duration="0:0:0.2"
                                                         EasingFunction="{StaticResource EaseOutCubic}"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1" Duration="0:0:0.2"
                                                         EasingFunction="{StaticResource EaseOutCubic}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                            <Setter Property="Foreground" Value="#0A1510"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#22D97E" Opacity="0.4"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryGlowBrush}"/>
