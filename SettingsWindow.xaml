<Window x:Class="BeiShuiCS2.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="设置"
        Width="880" Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <!-- 设置项容器 -->
        <Style x:Key="SettingItem" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,16"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- 设置分组标题 -->
        <Style x:Key="SettingGroupHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"/>
        <!-- 标题栏 -->
        <Grid Height="56" VerticalAlignment="Top" Margin="28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="设置" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    Click="Close_Click" VerticalAlignment="Center"/>
        </Grid>

        <!-- 内容区 -->
        <Grid Margin="28,72,28,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧标签页 (7个) -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,24,0">
                <StackPanel>
                    <Button x:Name="tabGeneral" Content="通用" Style="{StaticResource NavItemStyle}"
                            Click="TabGeneral_Click" Background="{StaticResource BgHoverBrush}"/>
                    <Button x:Name="tabDisplay" Content="显示" Style="{StaticResource NavItemStyle}"
                            Click="TabDisplay_Click"/>
                    <Button x:Name="tabGame" Content="游戏" Style="{StaticResource NavItemStyle}"
                            Click="TabGame_Click"/>
                    <Button x:Name="tabPrivacy" Content="隐私" Style="{StaticResource NavItemStyle}"
                            Click="TabPrivacy_Click"/>
                    <Button x:Name="tabNotifications" Content="通知" Style="{StaticResource NavItemStyle}"
                            Click="TabNotifications_Click"/>
                    <Button x:Name="tabHotkeys" Content="快捷键" Style="{StaticResource NavItemStyle}"
                            Click="TabHotkeys_Click"/>
                    <Button x:Name="tabMiniGames" Content="小游戏" Style="{StaticResource NavItemStyle}"
                            Click="TabMiniGames_Click"/>
                    <Button x:Name="tabTools" Content="工具" Style="{StaticResource NavItemStyle}"
                            Click="TabTools_Click"/>
                    <Button x:Name="tabAccount" Content="账号" Style="{StaticResource NavItemStyle}"
                            Click="TabAccount_Click"/>
                    <Button x:Name="tabAbout" Content="关于" Style="{StaticResource NavItemStyle}"
                            Click="TabAbout_Click" BorderThickness="0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- 右侧内容区 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                    <StackPanel x:Name="settingsContent">

                        <!-- ════════════ 通用设置 ════════════ -->
                        <StackPanel x:Name="panelGeneral">
                            <TextBlock Text="通用设置" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <!-- 开机自启 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="开机自启动" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="系统启动时自动运行背水平台" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleAutoStart"
                                                  Style="{StaticResource ToggleSwitchAnimated}"
                                                  Checked="ToggleAutoStart_Checked" Unchecked="ToggleAutoStart_Unchecked"/>
                                </Grid>
                            </Border>

                            <!-- 自动更新 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="自动更新" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="启动时自动检查并安装更新" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleAutoUpdate"
                                                  Style="{StaticResource ToggleSwitchAnimated}" IsChecked="True"/>
                                </Grid>
                            </Border>

                            <!-- 下载目录 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="下载目录" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Demo文件和资源的下载保存位置" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{StaticResource BgElevatedBrush}"
                                                CornerRadius="{StaticResource RadiusSmall}"
                                                BorderBrush="{StaticResource BorderPrimaryBrush}"
                                                BorderThickness="1" Padding="12,8" Margin="0,0,12,0">
                                            <TextBlock x:Name="txtDownloadPath" Text="默认"
                                                       Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                        </Border>
                                        <Button Grid.Column="1" Content="浏览"
                                                Style="{StaticResource BtnNeumorph}" Width="100" Height="40" FontSize="12"
                                                Click="BrowseDownloadPath_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- 缓存管理 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="缓存管理" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="txtCacheSize" Text="当前缓存: 0 MB" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Row="1" Content="清理缓存" Style="{StaticResource BtnNeumorph}"
                                            Width="110" FontSize="12"
                                            HorizontalAlignment="Left" Click="CleanCache_Click" Margin="0,0,0,-11"/>
                                </Grid>
                            </Border>

                            <!-- 语言 -->
                            <Border Style="{StaticResource SettingItem}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="界面语言" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="选择显示语言" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="cmbLanguage" Width="130" Height="34"
                                              Background="{StaticResource BgElevatedBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              BorderBrush="{StaticResource BorderPrimaryBrush}"
                                              SelectionChanged="Language_Changed">
                                        <ComboBoxItem Content="简体中文" Tag="zh-CN" IsSelected="True"/>
                                        <ComboBoxItem Content="English" Tag="en"/>
                                        <ComboBoxItem Content="日本語" Tag="ja"/>
                                        <ComboBoxItem Content="한국어" Tag="ko"/>
                                        <ComboBoxItem Content="Русский" Tag="ru"/>
                                        <ComboBoxItem Content="Español" Tag="es"/>
                                        <ComboBoxItem Content="Português (BR)" Tag="pt-BR"/>
                                        <ComboBoxItem Content="Deutsch" Tag="de"/>
                                        <ComboBoxItem Content="Français" Tag="fr"/>
                                        <ComboBoxItem Content="العربية" Tag="ar"/>
                                        <ComboBoxItem Content="Bahasa Indonesia" Tag="id"/>
                                        <ComboBoxItem Content="ภาษาไทย" Tag="th"/>
                                        <ComboBoxItem Content="Tiếng Việt" Tag="vi"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ════════════ 显示设置 ════════════ -->
                        <StackPanel x:Name="panelDisplay" Visibility="Collapsed">
                            <TextBlock Text="显示设置" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <!-- 界面缩放 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="界面缩放" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="调整界面元素的显示大小" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="cmbUiScale" Width="130" Height="34"
                                              Background="{StaticResource BgElevatedBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              BorderBrush="{StaticResource BorderPrimaryBrush}"
                                              SelectionChanged="UiScale_Changed">
                                        <ComboBoxItem Content="100%" Tag="1.0" IsSelected="True"/>
                                        <ComboBoxItem Content="125%" Tag="1.25"/>
                                        <ComboBoxItem Content="150%" Tag="1.5"/>
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- 动画效果 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="启用动画" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="开启或关闭界面过渡动画" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleAnimations"
                                                  Style="{StaticResource ToggleSwitchAnimated}" IsChecked="True"/>
                                </Grid>
                            </Border>

                            <!-- 动画速度 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="动画速度" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="控制界面动画的快慢" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="cmbAnimSpeed" Width="130" Height="34"
                                              Background="{StaticResource BgElevatedBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              BorderBrush="{StaticResource BorderPrimaryBrush}">
                                        <ComboBoxItem Content="快" Tag="fast"/>
                                        <ComboBoxItem Content="中" Tag="medium" IsSelected="True"/>
                                        <ComboBoxItem Content="慢" Tag="slow"/>
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- 侧栏折叠 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="自动折叠侧栏" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="鼠标离开时自动收起导航侧栏" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleCollapseSidebar"
                                                  Style="{StaticResource ToggleSwitchAnimated}"/>
                                </Grid>
                            </Border>

                            <!-- 主题选择 -->
                            <Border Style="{StaticResource SettingItem}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="界面主题" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="选择深色或浅色主题" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="cmbTheme" Width="130" Height="34"
                                              Background="{StaticResource BgElevatedBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              BorderBrush="{StaticResource BorderPrimaryBrush}"
                                              SelectionChanged="Theme_Changed">
                                        <ComboBoxItem Content="深色主题" Tag="dark" IsSelected="True"/>
                                        <ComboBoxItem Content="浅色主题" Tag="light"/>
                                        <ComboBoxItem Content="跟随系统" Tag="system"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ════════════ 游戏设置 ════════════ -->
                        <StackPanel x:Name="panelGame" Visibility="Collapsed">
                            <TextBlock Text="游戏设置" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <!-- CS2路径 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="CS2 启动路径" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="设置CS2可执行文件路径以便快速启动" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{StaticResource BgElevatedBrush}"
                                                CornerRadius="{StaticResource RadiusSmall}"
                                                BorderBrush="{StaticResource BorderPrimaryBrush}"
                                                BorderThickness="1" Padding="12,8" Margin="0,0,12,0">
                                            <TextBlock x:Name="txtCs2Path" Text="未设置"
                                                       Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                        </Border>
                                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource BtnNeumorph}"
                                                Width="100" Height="40" FontSize="12"
                                                Click="BrowseCs2Path_Click" Margin="0,0,8,0"/>
                                        <Button Grid.Column="2" Content="自动检测" Style="{StaticResource BtnPrimary}"
                                                Width="100" Height="36" FontSize="12" Click="RefreshCs2Path_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- 启动参数 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="启动参数" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="自定义CS2启动参数" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Row="1" Background="{StaticResource BgElevatedBrush}"
                                            CornerRadius="{StaticResource RadiusSmall}"
                                            BorderBrush="{StaticResource BorderPrimaryBrush}"
                                            BorderThickness="1">
                                        <TextBox x:Name="txtLaunchArgs" Background="Transparent" BorderThickness="0"
                                                 Padding="12,8" Foreground="{StaticResource TextPrimaryBrush}"
                                                 FontSize="13" FontFamily="{StaticResource FontMono}" Text="-novid -high"/>
                                    </Border>
                                    <Button Content="保存参数" Style="{StaticResource BtnPrimary}"
                                            Width="110" Height="36" FontSize="13" Margin="0,8,0,0" HorizontalAlignment="Right"
                                            Click="SaveLaunchArgs_Click"/>
                                </Grid>
                            </Border>

                            <!-- 启动后最小化 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="启动后最小化到托盘" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="启动CS2后自动最小化背水平台" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleMinimizeOnLaunch"
                                                  Style="{StaticResource ToggleSwitchAnimated}"/>
                                </Grid>
                            </Border>

                            <!-- 游戏内覆盖层 -->
                            <Border Style="{StaticResource SettingItem}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="游戏内覆盖层" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="游戏中显示帧率、网络状态等信息" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleInGameOverlay"
                                                  Style="{StaticResource ToggleSwitchAnimated}" IsChecked="True"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ════════════ 隐私设置 ════════════ -->
                        <StackPanel x:Name="panelPrivacy" Visibility="Collapsed">
                            <TextBlock Text="隐私设置" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <!-- 数据收集 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="匿名数据收集" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="帮助改进产品，仅收集匿名使用数据" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleDataCollection"
                                                  Style="{StaticResource ToggleSwitchAnimated}"/>
                                </Grid>
                            </Border>

                            <!-- 错误报告 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="自动错误报告" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="发生错误时自动发送诊断信息" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleErrorReports"
                                                  Style="{StaticResource ToggleSwitchAnimated}" IsChecked="True"/>
                                </Grid>
                            </Border>

                            <!-- 在线状态 -->
                            <Border Style="{StaticResource SettingItem}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="隐身模式" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="对好友显示为离线状态" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleInvisibleMode"
                                                  Style="{StaticResource ToggleSwitchAnimated}"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ════════════ 通知设置 ════════════ -->
                        <StackPanel x:Name="panelNotifications" Visibility="Collapsed">
                            <TextBlock Text="通知设置" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <!-- 匹配通知 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="匹配通知" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="匹配成功、对战邀请等通知" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleMatchNotifs"
                                                  Style="{StaticResource ToggleSwitchAnimated}" IsChecked="True"/>
                                </Grid>
                            </Border>

                            <!-- 好友通知 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="好友通知" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="好友上线、下线、邀请等通知" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleFriendNotifs"
                                                  Style="{StaticResource ToggleSwitchAnimated}" IsChecked="True"/>
                                </Grid>
                            </Border>

                            <!-- 系统通知 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="系统通知" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="更新公告、系统消息等通知" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleSystemNotifs"
                                                  Style="{StaticResource ToggleSwitchAnimated}" IsChecked="True"/>
                                </Grid>
                            </Border>

                            <!-- 勿扰模式 -->
                            <Border Style="{StaticResource SettingItem}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="勿扰模式" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="指定时间段内静音所有通知" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleDnd"
                                                  Style="{StaticResource ToggleSwitchAnimated}"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ════════════ 快捷键设置 ════════════ -->
                        <StackPanel x:Name="panelHotkeys" Visibility="Collapsed">
                            <TextBlock Text="快捷键设置" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <!-- 开始匹配 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="快速开始匹配" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="一键开始匹配对战" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}"
                                            CornerRadius="{StaticResource RadiusSmall}"
                                            BorderBrush="{StaticResource BorderPrimaryBrush}"
                                            BorderThickness="1" Padding="12,6">
                                        <TextBlock x:Name="txtHotkeyMatch" Text="F5"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="13"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- 截图 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="游戏内截图" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="快速截取游戏画面并保存" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}"
                                            CornerRadius="{StaticResource RadiusSmall}"
                                            BorderBrush="{StaticResource BorderPrimaryBrush}"
                                            BorderThickness="1" Padding="12,6">
                                        <TextBlock Text="F12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="13"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- 切换静音 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="切换语音静音" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="游戏中快速切换语音聊天开关" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}"
                                            CornerRadius="{StaticResource RadiusSmall}"
                                            BorderBrush="{StaticResource BorderPrimaryBrush}"
                                            BorderThickness="1" Padding="12,6">
                                        <TextBlock Text="F6"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="13"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- 显示/隐藏面板 -->
                            <Border Style="{StaticResource SettingItem}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="显示/隐藏覆盖层" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="切换游戏内信息覆盖层的显示" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}"
                                            CornerRadius="{StaticResource RadiusSmall}"
                                            BorderBrush="{StaticResource BorderPrimaryBrush}"
                                            BorderThickness="1" Padding="12,6">
                                        <TextBlock Text="F8"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="13"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ════════════ 小游戏 ════════════ -->
                        <StackPanel x:Name="panelMiniGames" Visibility="Collapsed">
                            <TextBlock Text="小游戏" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <!-- 游戏快捷启动 -->
                            <TextBlock Text="游戏中心" Style="{StaticResource SettingGroupHeader}"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Height="80"
                                        Style="{StaticResource BtnGhost}" Click="LaunchTicTacToe_Click">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="⭕" FontSize="28" HorizontalAlignment="Center"/>
                                        <TextBlock Text="井字棋" FontSize="13" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" Height="80"
                                        Style="{StaticResource BtnGhost}" Click="LaunchMemoryGame_Click">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="🧠" FontSize="28" HorizontalAlignment="Center"/>
                                        <TextBlock Text="记忆翻牌" FontSize="13" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" Height="80"
                                        Style="{StaticResource BtnGhost}" Click="LaunchSnakeGame_Click">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="🐍" FontSize="28" HorizontalAlignment="Center"/>
                                        <TextBlock Text="贪吃蛇" FontSize="13" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" Height="80"
                                        Style="{StaticResource BtnGhost}" Click="LaunchReactionGame_Click">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="⚡" FontSize="28" HorizontalAlignment="Center"/>
                                        <TextBlock Text="反应测试" FontSize="13" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- 猜数字 -->
                            <TextBlock Text="猜数字" Style="{StaticResource SettingGroupHeader}"/>
                            <Border Style="{StaticResource SettingItem}" BorderThickness="0">
                                <StackPanel>
                                    <TextBlock Text="电脑已随机生成一个 1-100 的数字，试试猜中它！" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource InputBox}" Padding="0" Margin="0,0,12,0" Height="36">
                                            <TextBox x:Name="txtGuess" Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     Padding="12,0" FontSize="14" FontFamily="{StaticResource FontMono}"/>
                                        </Border>
                                        <Button Grid.Column="1" Content="猜" Width="100" Height="40" FontSize="14"
                                                Style="{StaticResource BtnPrimary}" Click="GuessNumber_Click"/>
                                    </Grid>
                                    <TextBlock x:Name="txtGuessResult" Text="等待输入..." FontSize="13"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                                    <TextBlock x:Name="txtGuessCount" Text="" FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    <Button x:Name="btnGuessReset" Content="重新开始" Style="{StaticResource BtnGhost}"
                                            Width="110" Height="36" FontSize="13" Margin="0,8,0,0" HorizontalAlignment="Left"
                                            Click="ResetGuessGame_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ════════════ 工具 ════════════ -->
                        <StackPanel x:Name="panelTools" Visibility="Collapsed">
                            <TextBlock Text="实用工具" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <!-- 生日设置 -->
                            <TextBlock Text="个人设置" Style="{StaticResource SettingGroupHeader}"/>
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="生日" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="填写生日后，生日当天会收到平台祝福" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ComboBox x:Name="cmbBirthMonth" Width="100" Height="40"
                                                  Background="{StaticResource BgElevatedBrush}"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  FontSize="13" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="cmbBirthDay" Width="100" Height="40"
                                                  Background="{StaticResource BgElevatedBrush}"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  FontSize="13"/>
                                        <Button Content="保存" Style="{StaticResource BtnPrimary}"
                                                Width="100" Height="40" FontSize="12"
                                                Margin="8,0,0,0" Click="SaveBirthday_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 服务器连接设置 -->
                            <TextBlock Text="网络设置" Style="{StaticResource SettingGroupHeader}"/>
                            <Border Style="{StaticResource SettingItem}" Cursor="Hand" MouseLeftButtonDown="OpenServerConfig_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="服务器连接" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="txtServerStatus" Text="点击配置后端服务器地址"
                                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource PillBadgeActive}" Padding="8,4">
                                        <TextBlock Text="修改" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="启动时检查 IPv6" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="启动时检测本机 IPv6 状态并提示启用" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleIPv6Check"
                                                  Style="{StaticResource ToggleSwitchAnimated}" IsChecked="True"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingItem}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="检查 IPv6 状态" Style="{StaticResource BtnGhost}"
                                            Width="130" Height="36" FontSize="12" Click="CheckIPv6_Click"/>
                                    <Button Content="启用 IPv6" Style="{StaticResource BtnPrimary}"
                                            Width="110" Height="36" FontSize="12" Margin="8,0,0,0" Click="EnableIPv6_Click"/>
                                    <Button Content="禁用 IPv6" Style="{StaticResource BtnDanger}"
                                            Width="110" Height="36" FontSize="12" Margin="8,0,0,0" Click="DisableIPv6_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Base64 编解码 -->
                            <TextBlock Text="Base64 编解码" Style="{StaticResource SettingGroupHeader}"/>
                            <Border Style="{StaticResource SettingItem}">
                                <StackPanel>
                                    <Border Style="{StaticResource InputBox}" Padding="0" Height="36">
                                        <TextBox x:Name="txtBase64Input" Background="Transparent" BorderThickness="0"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 Padding="12,0" FontSize="13"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                                        <Button Content="编码 →" Width="100" Height="38" FontSize="13"
                                                Style="{StaticResource BtnPrimary}" Click="Base64Encode_Click" Margin="0,0,8,0"/>
                                        <Button Content="解码 →" Width="100" Height="38" FontSize="13"
                                                Style="{StaticResource BtnGhost}" Click="Base64Decode_Click"/>
                                    </StackPanel>
                                    <Border Style="{StaticResource InputBox}" Padding="12,8" MinHeight="36">
                                        <TextBlock x:Name="txtBase64Output" Text="结果将显示在这里"
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="13"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 颜色值转换 -->
                            <TextBlock Text="颜色值转换" Style="{StaticResource SettingGroupHeader}" Margin="0,16,0,0"/>
                            <Border Style="{StaticResource SettingItem}" BorderThickness="0">
                                <StackPanel>
                                    <TextBlock Text="输入 Hex 或 RGB 颜色值，查看转换结果" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource InputBox}" Padding="0" Height="36" Margin="0,0,12,0">
                                            <TextBox x:Name="txtColorInput" Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource TextPrimaryBrush}" FontFamily="{StaticResource FontMono}"
                                                     Padding="12,0" FontSize="13" Text="#4ADE80"/>
                                        </Border>
                                        <Button Grid.Column="1" Content="转换" Width="100" Height="40" FontSize="13"
                                                Style="{StaticResource BtnPrimary}" Click="ConvertColor_Click"/>
                                    </Grid>
                                    <Border x:Name="colorPreview" Width="40" Height="40" CornerRadius="8"
                                            Background="#4ADE80" Margin="0,12,0,0"/>
                                    <TextBlock x:Name="txtColorResult" Text="RGB: 74, 222, 128" FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ════════════ 账号设置 ════════════ -->
                        <StackPanel x:Name="panelAccount" Visibility="Collapsed">
                            <TextBlock Text="账号设置" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <!-- 修改密码 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="修改密码" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="定期更换密码以保护账号安全" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="修改" Style="{StaticResource BtnGhost}"
                                            MinWidth="110" Height="40" FontSize="13" Click="ChangePassword_Click"/>
                                </Grid>
                            </Border>

                            <!-- Steam绑定 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Steam 账号绑定" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="已绑定: demo_user" FontSize="12"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="解绑" Style="{StaticResource BtnDanger}"
                                            MinWidth="110" Height="40" FontSize="13" Click="UnbindSteam_Click"/>
                                </Grid>
                            </Border>

                            <!-- 登录通知 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="登录通知" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="新设备登录时发送通知提醒" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="toggleLoginNotifs"
                                                  Style="{StaticResource ToggleSwitchAnimated}" IsChecked="True"/>
                                </Grid>
                            </Border>

                            <!-- 高级验证 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="高级验证" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="完成验证解锁 Premium 功能" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="验证" Style="{StaticResource BtnPrimary}"
                                            MinWidth="110" Height="40" FontSize="13" Click="Verify_Click"/>
                                </Grid>
                            </Border>

                            <!-- 登录历史 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="登录历史" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="查看最近登录记录和登录设备" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="查看" Style="{StaticResource BtnGhost}"
                                            MinWidth="110" Height="40" FontSize="13" Click="LoginHistory_Click"/>
                                </Grid>
                            </Border>

                            <!-- 设备管理 -->
                            <Border Style="{StaticResource SettingItem}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="已登录设备" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="管理已登录的设备，远程下线" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="管理" Style="{StaticResource BtnGhost}"
                                            MinWidth="110" Height="40" FontSize="13" Click="DeviceManagement_Click"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ════════════ 关于 ════════════ -->
                        <StackPanel x:Name="panelAbout" Visibility="Collapsed">
                            <TextBlock Text="关于" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <!-- Logo & 版本信息 -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                                <Border Width="80" Height="80" CornerRadius="20" ClipToBounds="True" Margin="0,0,0,16">
                                    <Image Source="pack://application:,,,/default_avatar.png"
                                           Width="80" Height="80" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="背水对战平台" FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="版本 2.0.0 (Aurora)" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                <TextBlock Text="&#xA9; 2026 背水工作室" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- 检查更新 -->
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="检查更新" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="txtUpdateStatus" Text="点击检查是否有新版本可用" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Row="1" x:Name="btnCheckUpdate" Content="检查更新"
                                            Style="{StaticResource BtnPrimary}" Width="130" Height="38" FontSize="13"
                                            HorizontalAlignment="Left" Click="CheckUpdate_Click"/>
                                    <ProgressBar x:Name="updateProgressBar" Grid.Row="2" Visibility="Collapsed"
                                                 Margin="0,12,0,0" Height="4"
                                                 Foreground="{StaticResource PrimaryBrush}"
                                                 Background="{StaticResource BgElevatedBrush}"
                                                 BorderThickness="0"/>
                                </Grid>
                            </Border>

                            <!-- 软件信息 -->
                            <TextBlock Text="软件信息" Style="{StaticResource SettingGroupHeader}"/>
                            <Border Style="{StaticResource SettingItem}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="运行时" FontSize="13" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="NET 9.0 Windows" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="操作系统" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtOSVersion" Text="Windows" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="架构" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtIs64Bit" Text="..." FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="进程 ID" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtProcessId" Text="..." FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                </Grid>
                            </Border>

                            <!-- 开源许可 -->
                            <TextBlock Text="开源许可" Style="{StaticResource SettingGroupHeader}" Margin="0,16,0,0"/>
                            <Border Style="{StaticResource SettingItem}" BorderThickness="0">
                                <StackPanel>
                                    <TextBlock Text="本软件使用了以下开源组件：" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
