<Window x:Class="BeiShuiCS2.DuelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="1v1 对战"
        Width="560" Height="711"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="3"/>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center">
            <Border Width="52" Height="52" CornerRadius="26"
                    ClipToBounds="True"
                    HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="1v1 对战" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Tab 切换 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab 按钮 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,39">
                <Button x:Name="tabMatch" Content="🎯 随机匹配"
                        Style="{StaticResource BtnNeumorph}"
                        Width="140" Height="53" FontSize="13"
                        Click="TabMatch_Click"/>
                <Button x:Name="tabFriend" Content="👥 好友对战"
                        Style="{StaticResource BtnNeumorph}"
                        Width="140" Height="54" FontSize="13"
                        Margin="12,0,0,0" Click="TabFriend_Click"/>
            </StackPanel>

            <!-- 随机匹配面板 -->
            <StackPanel x:Name="panelMatch" Grid.Row="1" Visibility="Visible">
                <TextBlock Text="选择地图" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <ComboBox x:Name="cmbDuelMap" Margin="0,0,0,16" Height="40"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Background="{StaticResource BgElevatedBrush}"
                          BorderBrush="{StaticResource BorderPrimaryBrush}"
                          SelectedIndex="0">
                    <ComboBoxItem Content="荒漠迷城"/>
                    <ComboBoxItem Content="炼狱小镇"/>
                    <ComboBoxItem Content="死亡游乐园"/>
                    <ComboBoxItem Content="远古遗迹"/>
                </ComboBox>

                <!-- 匹配状态 -->
                <Border x:Name="matchStatusPanel" CornerRadius="{StaticResource RadiusMedium}"
                        Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource BorderPrimaryBrush}"
                        BorderThickness="1" Padding="20" Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="txtMatchStatus" Text="搜索中..."
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtMatchTimer" Text="00:00"
                                   FontSize="32" FontFamily="{StaticResource FontMono}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <ProgressBar IsIndeterminate="True" Height="3" Margin="0,12,0,0"
                                     Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- 对手信息 -->
                <Border x:Name="opponentPanel" CornerRadius="{StaticResource RadiusMedium}"
                        Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource PrimaryBrush}"
                        BorderThickness="1" Padding="20" Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="对手已找到！" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock x:Name="txtOpponentName" Text=""
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtOpponentMMR" Text=""
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <Button x:Name="btnAcceptDuel" Content="接受对战"
                                Style="{StaticResource BtnGradient}"
                                Height="44" FontSize="15"
                                Margin="0,16,0,0" Click="AcceptDuel_Click"/>
                        <Button Content="拒绝" Style="{StaticResource BtnGhost}"
                                Height="36" FontSize="13"
                                Margin="0,8,0,0" Click="RejectDuel_Click"/>
                    </StackPanel>
                </Border>

                <!-- 等待服务器 -->
                <Border x:Name="serverStartingPanel" CornerRadius="{StaticResource RadiusMedium}"
                        Background="{StaticResource BgElevatedBrush}"
                        Padding="20" Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="正在启动对战服务器..." FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar IsIndeterminate="True" Height="3" Margin="0,12,0,0"
                                     Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- 开始按钮 -->
                <Button x:Name="btnStartMatch" Content="开始匹配"
                        Style="{StaticResource BtnGradient}"
                        Height="48" FontSize="16"
                        Click="StartMatch_Click"/>
            </StackPanel>

            <!-- 好友对战面板 -->
            <StackPanel x:Name="panelFriend" Grid.Row="1" Visibility="Collapsed">
                <TextBlock Text="选择好友" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <ListBox x:Name="friendList" Background="Transparent" BorderThickness="0"
                         Height="200" Margin="0,0,0,12">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,8" CornerRadius="8"
                                    Background="{StaticResource BgElevatedBrush}"
                                    Margin="0,0,0,4">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="选择地图" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <ComboBox x:Name="cmbFriendMap" Margin="0,0,0,16" Height="40"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Background="{StaticResource BgElevatedBrush}"
                          BorderBrush="{StaticResource BorderPrimaryBrush}"
                          SelectedIndex="0">
                    <ComboBoxItem Content="荒漠迷城"/>
                    <ComboBoxItem Content="炼狱小镇"/>
                    <ComboBoxItem Content="死亡游乐园"/>
                    <ComboBoxItem Content="远古遗迹"/>
                </ComboBox>

                <Button x:Name="btnInvite" Content="邀约对战"
                        Style="{StaticResource BtnPrimary}"
                        Height="48" FontSize="15"
                        Click="InviteDuel_Click"/>

                <TextBlock x:Name="txtInviteStatus" Text=""
                           FontSize="13"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 关闭按钮 -->
        <Button Grid.Row="2" Content="关闭"
                Style="{StaticResource BtnNeumorph}"
                Width="120" FontSize="14"
                HorizontalAlignment="Center"
                Click="Close_Click" Margin="0,0,0,-2"/>
    </Grid>
</Window>
