<Window x:Class="BeiShuiCS2.QuickMatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快速匹配"
        Width="520" Height="907"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0,0,0,134">
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Margin="0,0,0,57"/>
        <Grid Margin="0,0,0,144">
            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 顶部：标题和关闭 -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="12"
                                Background="{StaticResource PrimaryGradientBrush}" Margin="0,0,12,0">
                            <TextBlock Text="&#xE7FC;" FontFamily="Segoe Fluent Icons"
                                       FontSize="20" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="快速匹配" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="正在为你寻找对手" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                            Style="{StaticResource WindowControlBtn}"
                            Click="Close_Click" VerticalAlignment="Top"/>
                </Grid>

                <!-- 中间：搜索状态 -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 搜索动画：脉冲圆圈 -->
                    <Border Grid.Row="0" Width="120" Height="120"
                            CornerRadius="60" Background="Transparent"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="3"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,24"
                            x:Name="pulseRing">
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="{StaticResource PrimaryGradientBrush}"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE7FC;" FontFamily="Segoe Fluent Icons"
                                       FontSize="32" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Border>

                    <!-- 搜索状态文字 -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock x:Name="txtStatus" Text="正在搜索对手..."
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtTimer" Text="00:00"
                                   FontSize="32" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- 匹配详情 -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20,16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="匹配模式"
                                       FontSize="13" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtMatchMode"
                                       Text="竞技 (5v5)" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="地图池"
                                       FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtMapPool"
                                       Text="Dust2, Mirage, Inferno" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="服务器"
                                       FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtServerRegion"
                                       Text="中国" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="队列人数"
                                       FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtQueueCount"
                                       Text="..." FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" Margin="0,8,0,0"/>
                        </Grid>
                    </Border>

                    <!-- 提示 -->
                    <Border Grid.Row="3" Background="{StaticResource BgElevatedBrush}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="16,12" Visibility="Collapsed" x:Name="tipBar">
                        <TextBlock x:Name="txtTip" Text="" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                    </Border>
                </Grid>

                <!-- 底部：取消按钮 -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button x:Name="btnCancel" Content="取消匹配"
                            Style="{StaticResource BtnNeumorph}"
                            Width="160" Height="53" FontSize="15"
                            Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
