<Window x:Class="BeiShuiCS2.WelfareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="背水公益"
        Width="1416" Height="1227"
        MinWidth="700" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="4"/>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16" HorizontalAlignment="Center">
            <Border Width="56" Height="56" CornerRadius="28"
                    Background="{StaticResource PrimaryGradientBrush}"
                    HorizontalAlignment="Center" Margin="0,0,0,10"
                    RenderTransformOrigin="0.5,0.5">
                <TextBlock Text="&#x2665;" FontFamily="Segoe UI"
                           FontSize="28" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="背水公益" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="用游戏连接世界，用爱心温暖人间"
                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 公益项目列表 -->
        <ItemsControl x:Name="welfareList" Grid.Row="1" BorderThickness="0"
                      Background="Transparent" Margin="0,0,0,12">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="{StaticResource RadiusMedium}"
                            Margin="0,0,0,10" Padding="20,16"
                            Cursor="Hand" Tag="{Binding Link}"
                            MouseLeftButtonDown="WelfareItem_Click">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="{Binding Color1Obj}"/>
                                <GradientStop Offset="1" Color="{Binding Color2Obj}"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="48" Height="48"
                                    CornerRadius="24" Background="#33FFFFFF"
                                    Margin="0,0,16,0">
                                <TextBlock Text="{Binding Icon}" FontSize="24"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontSize="17"
                                           FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding Summary}" FontSize="12"
                                           Foreground="#DDFFFFFF" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="›" FontSize="28"
                                       Foreground="#AAFFFFFF" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 内容浏览区 -->
        <Border Grid.Row="2" CornerRadius="{StaticResource RadiusMedium}"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="1" ClipToBounds="True">
            <Grid>
                <wv2:WebView2 x:Name="webContent" Margin="0,0,0,0"/>
                <TextBlock x:Name="txtLoading" Text="点击上方公益项目查看详情"
                           FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <Button Grid.Row="3" Content="关闭" Style="{StaticResource BtnNeumorph}"
                Width="120" FontSize="14"
                HorizontalAlignment="Center" Margin="0,10,0,0" Click="Close_Click"/>
    </Grid>
</Window>
