<Window x:Class="BeiShuiCS2.CreateServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="创建对战服务器"
        Width="560" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="3"/>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24" HorizontalAlignment="Center">
            <Border Width="52" Height="52" CornerRadius="26"
                    Background="{StaticResource PrimaryGradientBrush}"
                    HorizontalAlignment="Center" Margin="0,0,0,12">
                <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons"
                           FontSize="26" Foreground="{StaticResource BgDeepBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="创建对战服务器" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="配置你的 CS2 专属服务器，邀请好友一起玩"
                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 表单 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- 地图选择 -->
                <TextBlock Text="地图" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <ComboBox x:Name="cmbMap" Margin="0,0,0,16" Height="42"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Background="{StaticResource BgElevatedBrush}"
                          BorderBrush="{StaticResource BorderPrimaryBrush}">
                    <ComboBoxItem Content="荒漠迷城 de_mirage" IsSelected="True"/>
                    <ComboBoxItem Content="炼狱小镇 de_inferno"/>
                    <ComboBoxItem Content="死亡游乐园 de_overpass"/>
                    <ComboBoxItem Content="远古遗迹 de_ancient"/>
                    <ComboBoxItem Content="核子危机 de_nuke"/>
                    <ComboBoxItem Content="阿努比斯 de_anubis"/>
                    <ComboBoxItem Content="殒命大厦 de_vertigo"/>
                    <ComboBoxItem Content="炙热沙城Ⅱ de_dust2"/>
                </ComboBox>

                <!-- 模式 -->
                <TextBlock Text="游戏模式" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <ComboBox x:Name="cmbMode" Margin="0,0,0,16" Height="42"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Background="{StaticResource BgElevatedBrush}"
                          BorderBrush="{StaticResource BorderPrimaryBrush}">
                    <ComboBoxItem Content="竞技模式" IsSelected="True"/>
                    <ComboBoxItem Content="休闲模式"/>
                    <ComboBoxItem Content="死斗模式"/>
                </ComboBox>

                <!-- 最大玩家 -->
                <TextBlock Text="最大玩家数" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <Slider x:Name="sliderPlayers" Minimum="2" Maximum="10" Value="10"
                        TickFrequency="1" TickPlacement="BottomRight"
                        IsSnapToTickEnabled="True"
                        Margin="0,0,0,8"/>
                <TextBlock x:Name="txtPlayerCount" Text="10 人"
                           FontSize="14" Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>

                <!-- 密码 -->
                <TextBlock Text="密码（可选）" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <Border Background="{StaticResource BgElevatedBrush}"
                        CornerRadius="{StaticResource RadiusSmall}"
                        BorderBrush="{StaticResource BorderPrimaryBrush}"
                        BorderThickness="1" Margin="0,0,0,16">
                    <TextBox x:Name="txtPassword" Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Padding="12,10" FontSize="14"/>
                </Border>

                <!-- 结果区域 -->
                <Border x:Name="resultPanel" Visibility="Collapsed"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource PrimaryBrush}"
                        BorderThickness="1" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="✅ 服务器已创建" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,12"/>
                        <TextBlock x:Name="txtServerAddress" Text=""
                                   FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Button Content="复制服务器地址" Style="{StaticResource BtnGhost}"
                                Margin="0,12,0,0" Click="CopyAddress_Click"/>
                    </StackPanel>
                </Border>

                <!-- 加载状态 -->
                <Border x:Name="loadingPanel" Visibility="Collapsed"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Background="{StaticResource BgElevatedBrush}"
                        Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="正在启动服务器..." FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,12,0,0"
                                     Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,12,0,0">
            <Button x:Name="btnCreate" Content="🎮 创建服务器"
                    Style="{StaticResource BtnPrimary}"
                    Width="160" Height="50" FontSize="15"
                    Click="Create_Click"/>
            <Button Content="取消" Style="{StaticResource BtnNeumorph}"
                    Width="100" Height="50" FontSize="14"
                    Margin="12,0,0,0" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
