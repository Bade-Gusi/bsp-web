<Window x:Class="BeiShuiCS2.VerifyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="高级验证" 
        Width="520" Height="643"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">


    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 关闭按钮 -->
        <Button Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                Style="{StaticResource WindowControlBtn}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Click="Close_Click"/>

        <!-- 标题 -->
        <TextBlock Grid.Row="1" Text="&#xE9CE;" FontFamily="Segoe Fluent Icons"
                   FontSize="40" Foreground="{StaticResource PrimaryBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
        <TextBlock Grid.Row="2" Text="高级验证" FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="3" Text="完成验证以解锁全部功能"
                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,32"/>

        <!-- 验证步骤 -->
        <StackPanel Grid.Row="4">
            <!-- 步骤1 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Height="93">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                            Background="{StaticResource PrimaryBrush}" Margin="0,0,16,0">
                        <TextBlock Text="1" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource BgDeepBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="邮箱验证" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="验证你的邮箱地址" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="验证" Style="{StaticResource BtnPrimary}"
                            Width="80" FontSize="12" Click="VerifyEmail_Click" Margin="0,8,0,1"/>
                </Grid>
            </Border>

            <!-- 步骤2 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Height="92">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                            Background="{StaticResource BgElevatedBrush}" Margin="0,0,16,0">
                        <TextBlock Text="2" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="手机绑定" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="绑定手机号增强安全性" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="绑定" Style="{StaticResource BtnGhost}"
                            Width="80" FontSize="12" Click="BindPhone_Click" Margin="0,7,0,0"/>
                </Grid>
            </Border>

            <!-- 步骤3 -->
            <Border Style="{StaticResource CardStyle}" Height="87">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                            Background="{StaticResource BgElevatedBrush}" Margin="0,0,16,0">
                        <TextBlock Text="3" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="身份认证" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="完成实名认证" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="认证" Style="{StaticResource BtnGhost}"
                            Width="80" FontSize="12" Click="VerifyIdentity_Click" Margin="0,4,0,-1"/>
                </Grid>
            </Border>

            <Button Content="关闭" Style="{StaticResource BtnGhost}"
                    Width="120" Height="44" Margin="0,24,0,0"
                    HorizontalAlignment="Center" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
