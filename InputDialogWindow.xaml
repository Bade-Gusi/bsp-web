<Window x:Class="BeiShuiCS2.InputDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:e="clr-namespace:BeiShuiCS2"
        Title="输入" 
        Width="420" Height="251"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">


    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="txtTitle" Text="输入内容" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" x:Name="txtDescription" Text="" FontSize="13"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,16"/>

        <Border Grid.Row="2" Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusMedium}"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="1" Margin="0,0,0,24">
            <TextBox x:Name="txtInput"
                     Background="Transparent" BorderThickness="0"
                     Padding="12,10" Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="14" CaretBrush="{StaticResource PrimaryBrush}"/>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="取消" Style="{StaticResource BtnGhost}"
                    Width="100" Height="44" Margin="0,0,12,0"
                    Click="Cancel_Click"/>
            <Button Content="确认" Style="{StaticResource BtnPrimary}"
                    Width="100" Height="40" Click="Confirm_Click">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                      Opacity="0.4" Color="{StaticResource PrimaryColor}"/>
                </Button.Effect>
            </Button>
        </StackPanel>
    </Grid>
</Window>

