<Window x:Class="BeiShuiCS2.MatchingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="匹配队列"
        Width="1100" Height="740"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <!-- 玩家卡片模板 -->
        <DataTemplate x:Key="PlayerCardTemplate">
            <Border Width="180" Height="64" Margin="0,0,0,8"
                    CornerRadius="{StaticResource RadiusMedium}"
                    Background="{StaticResource BgElevatedBrush}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                    BorderThickness="1">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- 玩家头像占位 -->
                    <Border Grid.Column="0" Width="40" Height="40"
                            CornerRadius="20" Background="{StaticResource BgDeepBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons"
                                   FontSize="18" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- 玩家信息 -->
                    <StackPanel Grid.Column="1" Margin="8,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Rank}" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="0,0,0,-4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"/>

        <!-- ========== 顶部栏 ========== -->
        <Grid Grid.Row="0" Height="64" Margin="32,16,32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 标题 + 状态 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="匹配队列" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Border Background="{StaticResource WarningBrush}"
                        CornerRadius="{StaticResource RadiusFull}"
                        Padding="10,4" Margin="16,0,0,0"
                        x:Name="statusBadge">
                    <TextBlock x:Name="txtStatus" Text="准备就绪"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource BgDeepBrush}"/>
                </Border>
                <Border Background="{StaticResource BgElevatedBrush}"
                        CornerRadius="{StaticResource RadiusFull}"
                        Padding="10,4" Margin="8,0,0,0"
                        Visibility="Collapsed" x:Name="timerBadge">
                    <TextBlock x:Name="txtTimer" Text="00:00"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource FontMono}"/>
                </Border>
            </StackPanel>

            <!-- 地图信息 -->
            <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}"
                    CornerRadius="{StaticResource RadiusMedium}"
                    Padding="14,8" Margin="0,0,12,0"
                    VerticalAlignment="Center">
                <TextBlock x:Name="txtMapName" Text="de_dust2"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="{StaticResource FontMono}"/>
            </Border>

            <!-- 取消按钮 -->
            <Button Grid.Column="2" x:Name="btnCancel" Content="取消匹配"
                    Style="{StaticResource BtnDanger}"
                    Width="120" Height="40" FontSize="14"
                    Click="Cancel_Click"/>
        </Grid>

        <!-- ========== 主对战区 ========== -->
        <Grid Grid.Row="1" Margin="32,24,32,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 蓝队 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}"
                    Background="{StaticResource BgCardBrush}"
                    BorderBrush="#3B82F6" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                      Opacity="0.2" Color="#3B82F6"/>
                </Border.Effect>
                <StackPanel Margin="16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Ellipse Width="10" Height="10" Fill="#3B82F6" Margin="0,0,8,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="反恐精英 (CT)" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource InfoBrush}"/>
                        <TextBlock x:Name="txtBlueCount" Text="0/5"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                   Margin="8,2,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                        <ItemsControl x:Name="blueTeamList"
                                      ItemTemplate="{StaticResource PlayerCardTemplate}"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- VS 中间区 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="28,0">
                <TextBlock x:Name="txtVS" Text="VS" FontSize="64" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <!-- 搜索动画 -->
                <Grid x:Name="searchSpinner" Width="48" Height="48" Margin="0,20,0,0"
                      HorizontalAlignment="Center" Visibility="Collapsed">
                    <Ellipse x:Name="loadingRing" Width="40" Height="40"
                             Stroke="{StaticResource PrimaryBrush}"
                             StrokeThickness="3"
                             StrokeDashArray="20,10"
                             Fill="None"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>

                <!-- 操作按钮 -->
                <StackPanel Margin="0,24,0,0" Visibility="Collapsed" x:Name="actionPanel">
                    <Button x:Name="btnAccept" Content="接受匹配"
                            Style="{StaticResource BtnPrimary}"
                            Width="140" Height="48" FontSize="15"
                            Click="AcceptDuel_Click"/>
                    <Button x:Name="btnReject" Content="拒绝"
                            Style="{StaticResource BtnGhost}"
                            Width="140" Height="40" FontSize="14"
                            Margin="0,8,0,0"
                            Click="RejectMatch_Click"/>
                </StackPanel>

                <!-- 空状态提示 -->
                <TextBlock x:Name="txtEmptyHint" Text="点击下方「开始匹配」寻找对手"
                           FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,16,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- 红队 -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}"
                    Background="{StaticResource BgCardBrush}"
                    BorderBrush="#EF4444" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                      Opacity="0.2" Color="#EF4444"/>
                </Border.Effect>
                <StackPanel Margin="16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Ellipse Width="10" Height="10" Fill="#EF4444" Margin="0,0,8,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="恐怖分子 (T)" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource DangerBrush}"/>
                        <TextBlock x:Name="txtRedCount" Text="0/5"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                   Margin="8,2,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                        <ItemsControl x:Name="redTeamList"
                                      ItemTemplate="{StaticResource PlayerCardTemplate}"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ========== 底部操作栏 ========== -->
        <Border Grid.Row="2" Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusMedium}"
                Margin="32,0,32,24" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="txtBottomHint"
                           Text="点击「开始匹配」加入匹配队列，系统将自动为你寻找实力相近的对手"
                           FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" x:Name="btnStartMatch" Content="开始匹配"
                        Style="{StaticResource BtnPrimary}"
                        Width="140" Height="40" FontSize="14"
                        Click="StartMatch_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
