<Window x:Class="BeiShuiCS2.AntiCheatWarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:e="clr-namespace:BeiShuiCS2"
        Title="反作弊警告" 
        Width="480" Height="283"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">


    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"/>

        <TextBlock Grid.Row="0" Text="&#xE7BA;" FontFamily="Segoe Fluent Icons"
                   FontSize="48" Foreground="{StaticResource WarningBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Text="反作弊未通过" FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource WarningBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2" Text="请先完成反作弊验证才能开始游戏"
                   FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" TextWrapping="Wrap"
                   TextAlignment="Center" Margin="0,0,0,24"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <Button Content="去验证" Style="{StaticResource BtnPrimary}"
                    Width="120" Height="44" Click="Verify_Click">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                      Opacity="0.4" Color="{StaticResource PrimaryColor}"/>
                </Button.Effect>
            </Button>
            <Button Content="取消" Style="{StaticResource BtnGhost}"
                    Width="120" Height="44" Margin="12,0,0,0"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>

