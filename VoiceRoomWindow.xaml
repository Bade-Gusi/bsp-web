<Window x:Class="BeiShuiCS2.VoiceRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="语音房间"
        Width="860" Height="620"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"
                Grid.ColumnSpan="2"/>

        <!-- 左侧：房间列表 -->
        <Border Grid.Column="0" CornerRadius="{StaticResource RadiusMedium}"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="1" Margin="0,0,12,0">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="语音房间" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="加入或创建语音频道" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="roomListPanel"/>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="+ 创建" Style="{StaticResource BtnPrimary}"
                            Height="40" FontSize="12" Width="100"
                            Click="CreateRoom_Click"/>
                    <Button Content="加入" Style="{StaticResource BtnGhost}"
                            Height="40" FontSize="12" Width="80"
                            Margin="8,0,0,0" Click="JoinRoom_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 右侧：当前房间 -->
        <Border Grid.Column="1" CornerRadius="{StaticResource RadiusMedium}"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="1">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 房间标题 -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="txtCurrentRoom" Text="选择一个房间"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="txtRoomCode" Text=""
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="进入语音" Style="{StaticResource BtnGradient}"
                                Height="43" FontSize="12"
                                Click="JoinVoice_Click"/>
                        <Button Content="离开" Style="{StaticResource BtnGhost}"
                                Height="43" FontSize="12" Margin="8,0,0,0"
                                Click="LeaveRoom_Click"/>
                    </StackPanel>
                </Grid>

                <!-- 成员列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="memberList" Background="Transparent"
                                  BorderThickness="0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" Margin="0,0,0,4"
                                        CornerRadius="8"
                                        Background="{StaticResource BgElevatedBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="36" Height="36"
                                                CornerRadius="18"
                                                Background="{StaticResource PrimaryGradientBrush}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Initial}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Badge}"
                                                           FontSize="10" Margin="6,0,0,0"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                        <Ellipse Grid.Column="2" Width="8" Height="8"
                                                 Fill="{StaticResource PrimaryBrush}"
                                                 VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 底部提示 -->
                <TextBlock Grid.Row="2" Text="点击左侧房间加入，或创建自己的语音频道"
                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
