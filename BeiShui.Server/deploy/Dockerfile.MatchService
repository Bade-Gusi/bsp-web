FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src
COPY src/BeiShui.MatchService/BeiShui.MatchService.csproj .
RUN dotnet restore
COPY src/BeiShui.MatchService/ .
RUN dotnet publish -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:9.0
WORKDIR /app
COPY --from=build /app .
ENTRYPOINT ["dotnet", "BeiShui.MatchService.dll"]
