FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src
COPY src/BeiShui.ApiGateway/BeiShui.ApiGateway.csproj .
RUN dotnet restore
COPY src/BeiShui.ApiGateway/ .
RUN dotnet publish -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:9.0
WORKDIR /app
COPY --from=build /app .
EXPOSE 5000
ENTRYPOINT ["dotnet", "BeiShui.ApiGateway.dll"]
