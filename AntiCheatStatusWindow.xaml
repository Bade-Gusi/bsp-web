<Window x:Class="BeiShuiCS2.AntiCheatStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="反作弊系统" 
        Width="700" Height="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <!-- 状态指示器脉冲 -->
        <Storyboard x:Key="StatusPulse" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.4" To="1" Duration="0:0:1.5"
                             AutoReverse="True"/>
        </Storyboard>

        <!-- 环形进度条样式 -->
        <Style x:Key="CircularProgress" TargetType="ProgressBar">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="120"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Ellipse Stroke="{StaticResource BgElevatedBrush}" StrokeThickness="8" Fill="None"/>
                            <Ellipse x:Name="progressRing" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="8"
                                     Fill="None" StrokeDashArray="100" StrokeDashOffset="100"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Height="64" Margin="32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE9CE;" FontFamily="Segoe Fluent Icons"
                           FontSize="28" Foreground="{StaticResource PrimaryBrush}"
                           Margin="0,0,16,0"/>
                <TextBlock Text="反作弊系统" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    Click="Close_Click"/>
        </Grid>

        <!-- 状态概览 -->
        <Grid Grid.Row="1" Margin="32,0,32,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 整体状态 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <StackPanel HorizontalAlignment="Center">
                    <Ellipse Width="16" Height="16" Fill="{StaticResource PrimaryBrush}" Margin="0,0,0,12">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource StatusPulse}"/>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="运行正常" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="所有模块工作正常" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 扫描次数 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="txtScanCount" Text="1,247" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="今日扫描" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 拦截数 -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="0" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="异常拦截" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 详细日志 + 按钮 -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="32,0,32,32">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="实时日志" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,16"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="logPanel">
                        <Border Style="{StaticResource ListItemHover}" Padding="12" Margin="0,0,0,4">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Text="[10:23:45]" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="{StaticResource FontMono}"/>
                                    <TextBlock Text=" 系统初始化完成" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ListItemHover}" Padding="12" Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="[10:23:46]" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource FontMono}"/>
                                <TextBlock Text=" 内存扫描模块已加载" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ListItemHover}" Padding="12" Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="[10:23:47]" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource FontMono}"/>
                                <TextBlock Text=" 进程监控已启动" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ListItemHover}" Padding="12" Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource InfoBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="[10:24:15]" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource FontMono}"/>
                                <TextBlock Text=" 定期扫描完成，未发现异常" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ListItemHover}" Padding="12" Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource InfoBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="[10:25:30]" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource FontMono}"/>
                                <TextBlock Text=" 定期扫描完成，未发现异常" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" Content="&#xE768; 手动心跳检测" Style="{StaticResource BtnGhost}"
                        Click="HeartbeatCheck_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
