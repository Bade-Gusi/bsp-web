<Window x:Class="BeiShuiCS2.AddFriendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:e="clr-namespace:BeiShuiCS2"
        Title="添加好友" 
        Width="460" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">


    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"/>

        <TextBlock Grid.Row="0" Text="&#xE716;" FontFamily="Segoe Fluent Icons"
                   FontSize="40" Foreground="{StaticResource PrimaryBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
        <TextBlock Grid.Row="1" Text="添加好友" Style="{StaticResource PageHeader}"
                   HorizontalAlignment="Center"/>
        <TextBlock Grid.Row="2" Text="输入好友的用户名或 Steam ID"
                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,32"/>

        <StackPanel Grid.Row="3">
            <Border Background="{StaticResource BgElevatedBrush}"
                    CornerRadius="{StaticResource RadiusMedium}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                    BorderThickness="1" Margin="0,0,0,16">
                <Grid>
                    <TextBox x:Name="txtFriendId"
                             Background="Transparent" BorderThickness="0"
                             Padding="16,12" Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="14" CaretBrush="{StaticResource PrimaryBrush}"/>
                    <TextBlock x:Name="lblPlaceholder" Text="用户名 / Steam ID"
                               Foreground="{StaticResource TextMutedBrush}"
                               Padding="16,12" IsHitTestVisible="False"
                               FontSize="14" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Button x:Name="btnSearch" Content="&#xE721; 搜索"
                    Style="{StaticResource BtnPrimary}"
                    Height="48" FontSize="16" Click="Search_Click">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                      Opacity="0.4" Color="{StaticResource PrimaryColor}"/>
                </Button.Effect>
            </Button>

            <StackPanel x:Name="resultPanel" Margin="0,16,0,0" Visibility="Collapsed">
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24"
                                Background="{StaticResource PrimaryBrush}">
                            <TextBlock x:Name="txtResultInitial" Text="?"
                                       Foreground="{StaticResource BgDeepBrush}"
                                       FontWeight="Bold" FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0">
                            <TextBlock x:Name="txtResultName" Text="User"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="txtResultId" Text="Steam: 123456"
                                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="{StaticResource FontMono}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="添加"
                                Style="{StaticResource BtnPrimary}"
                                Width="80" Height="36" FontSize="12"
                                Click="Add_Click"/>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>

        <Button Grid.Row="4" Content="取消" Style="{StaticResource BtnGhost}"
                Width="120" Height="44" Margin="0,16,0,0"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Click="Cancel_Click"/>
    </Grid>
</Window>

