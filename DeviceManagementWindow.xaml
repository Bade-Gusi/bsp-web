<Window x:Class="BeiShuiCS2.DeviceManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="已登录设备管理"
        Width="640" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"/>

        <!-- 标题栏 -->
        <Grid Height="56" VerticalAlignment="Top" Margin="28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="已登录设备" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    Click="Close_Click" VerticalAlignment="Center"/>
        </Grid>

        <!-- 提示文字 -->
        <TextBlock x:Name="txtHint" Text="以下设备已登录您的账号，可远程下线陌生设备"
                   FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                   Margin="28,72,28,0" VerticalAlignment="Top"/>

        <!-- 设备列表 -->
        <ScrollViewer Margin="28,100,28,28"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="deviceListPanel"/>
        </ScrollViewer>

        <!-- 底部操作栏 -->
        <Border Height="64" VerticalAlignment="Bottom"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="0,1,0,0"
                Padding="28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="txtDeviceCount"
                           Text="共 0 台设备" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="关闭" Style="{StaticResource BtnGhost}"
                        MinWidth="100" FontSize="13" Click="Close_Click" Margin="0,6,0,13"/>
            </Grid>
        </Border>
    </Grid>
</Window>
