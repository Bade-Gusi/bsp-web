<Window x:Class="BeiShuiCS2.AntiCheatHeartbeatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="反作弊心跳验证"
        Width="480" Height="668"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="False"
        Background="Transparent"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="8"/>

        <!-- Shield 图标 + 脉冲环 -->
        <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0,4,0,8">
            <Ellipse x:Name="pulseRingOuter" Width="100" Height="100"
                     Stroke="{StaticResource WarningBrush}" StrokeThickness="2"
                     Opacity="0.4" RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <Border Width="64" Height="64" CornerRadius="32"
                    Background="{StaticResource BgElevatedBrush}"
                    BorderBrush="{StaticResource WarningBrush}" BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#FBBF24" Opacity="0.4"/>
                </Border.Effect>
                <TextBlock Text="&#xE9CE;" FontFamily="Segoe Fluent Icons"
                           FontSize="28" Foreground="{StaticResource WarningBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- 标题 -->
        <TextBlock Grid.Row="1" Text="反作弊心跳验证" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" Margin="0,0,0,2"/>
        <TextBlock Grid.Row="2" Text="实时向游戏服务器发送心跳包" FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>

        <!-- 状态指示器 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
            <Border Style="{StaticResource PillBadge}" Padding="8,4" Margin="0,0,6,0">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="dotAntiCheat" Width="6" Height="6" Fill="{StaticResource PrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="反作弊" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PillBadge}" Padding="8,4" Margin="0,0,6,0">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="dotIntegrity" Width="6" Height="6" Fill="{StaticResource PrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="完整性" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PillBadge}" Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="dotNetwork" Width="6" Height="6" Fill="{StaticResource AccentTealBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="心跳" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 心跳实时信息 -->
        <Border Grid.Row="4" Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusMedium}" Padding="12,8" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock x:Name="txtPacketInfo" Text="💓 心跳包: 等待发送..."
                           FontSize="12" FontFamily="{StaticResource FontMono}" Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock x:Name="txtClientStatus" Text="状态: 初始化中..."
                           FontSize="12" FontFamily="{StaticResource FontMono}" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                <TextBlock x:Name="txtFingerprint" Text=""
                           FontSize="11" FontFamily="{StaticResource FontMono}" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <!-- 关闭按钮 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,6">
            <Grid Width="72" Height="72" Margin="0,0,20,0" Visibility="Collapsed">
                <Ellipse x:Name="countdownRing" Width="72" Height="72"
                         Stroke="{StaticResource BgElevatedBrush}" StrokeThickness="5" Fill="Transparent"/>
                <TextBlock x:Name="txtCountdown" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           FontFamily="{StaticResource FontMono}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <StackPanel VerticalAlignment="Center">
                <Button x:Name="btnVerify" Content="&#xE9CE; 心跳验证"
                        Style="{StaticResource BtnNeumorph}"
                        Height="44" Width="160" FontSize="14" FontWeight="Bold"
                        Visibility="Collapsed">
                    <Button.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#4ADE80" Offset="0"/>
                            <GradientStop Color="#2DD4BF" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Foreground>
                </Button>
                <Button x:Name="btnClose" Content="&#xE8BB; 关闭"
                        Style="{StaticResource BtnNeumorph}"
                        Height="54" Width="160" FontSize="14"
                        Click="Close_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- 日志标题 -->
        <TextBlock Grid.Row="6" Text="心跳日志" FontSize="11" FontWeight="SemiBold"
                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>

        <!-- 日志列表 -->
        <Border Grid.Row="6" Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusMedium}" Padding="8,6" Margin="0,22,0,0">
            <ListBox x:Name="lbLogs" Background="Transparent" BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" FontFamily="{StaticResource FontMono}" Margin="0,1"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</Window>
