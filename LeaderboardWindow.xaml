<Window x:Class="BeiShuiCS2.LeaderboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="排行榜" 
        Width="900" Height="750"
        WindowStartupLocation="CenterOwner"
        MinWidth="700" MinHeight="600" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <!-- 排名徽章样式 -->
        <Style x:Key="RankBadge" TargetType="Border">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Height="64" Margin="32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE9D2;" FontFamily="Segoe Fluent Icons"
                           FontSize="28" Foreground="{StaticResource WarningBrush}"
                           Margin="0,0,16,0"/>
                <TextBlock Text="排行榜" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="&#xE721;" FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource WindowControlBtn}"
                        Click="Refresh_Click"/>
                <Button Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource WindowControlBtn}"
                        Margin="8,0,0,0" Click="Close_Click"/>
            </StackPanel>
        </Grid>

        <!-- 筛选标签 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="32,0,32,16">
            <Button x:Name="tabRating" Content="Rating" Style="{StaticResource BtnPrimary}"
                    Width="100" Height="45" Margin="0,0,8,0" Click="TabRating_Click"/>
            <Button x:Name="tabWinRate" Content="胜率" Style="{StaticResource BtnGhost}"
                    Width="100" Height="46" Margin="0,0,8,0" Click="TabWinRate_Click"/>
            <Button x:Name="tabKills" Content="击杀" Style="{StaticResource BtnGhost}"
                    Width="100" Height="46" Margin="0,0,8,0" Click="TabKills_Click"/>
            <Button x:Name="tabMatches" Content="场次" Style="{StaticResource BtnGhost}"
                    Width="100" Height="46" Click="TabMatches_Click"/>
        </StackPanel>

        <!-- 前三名 podium -->
        <Grid Grid.Row="2" Margin="32,0,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top 3 Podium -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- #2 -->
                <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Opacity="0"
                            x:Name="podium2">
                    <Border Width="70" Height="70" CornerRadius="35"
                            Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="#C0C0C0" BorderThickness="3"
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="2" FontSize="28" FontWeight="Bold"
                                   Foreground="#C0C0C0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="txtName2" Text="Player2" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtScore2" Text="2,100" FontSize="18" FontWeight="Bold"
                               Foreground="#C0C0C0"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- #1 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,0,20" Opacity="0"
                            x:Name="podium1">
                    <Border Width="80" Height="80" CornerRadius="40"
                            Background="{StaticResource PrimaryBrush}"
                            BorderBrush="#FFD700" BorderThickness="3"
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                              Opacity="0.5" Color="#FFD700"/>
                        </Border.Effect>
                        <TextBlock Text="1" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource BgDeepBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="txtName1" Text="Player1" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtScore1" Text="2,500" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- #3 -->
                <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Opacity="0"
                            x:Name="podium3">
                    <Border Width="60" Height="60" CornerRadius="30"
                            Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="#CD7F32" BorderThickness="3"
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="3" FontSize="24" FontWeight="Bold"
                                   Foreground="#CD7F32"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="txtName3" Text="Player3" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtScore3" Text="1,950" FontSize="18" FontWeight="Bold"
                               Foreground="#CD7F32"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- 列表 -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="leaderboardList" Margin="16">
                        <!-- 动态生成 -->
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
