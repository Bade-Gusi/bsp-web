<Window x:Class="BeiShuiCS2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:e="clr-namespace:BeiShuiCS2"
        Title="背水对战平台" 
        Width="1825" Height="1058"
        MinWidth="1300" MinHeight="750"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Style="{DynamicResource MainAuroraWindow}" WindowStyle="None">

    <Window.Resources>
        <!-- 3D倾斜卡片效果 -->
        <Style x:Key="TiltCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardGradientBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 状态指示器样式 -->
        <Style x:Key="StatusIndicator" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- 数据卡片样式 -->
        <Style x:Key="StatCard" TargetType="Border" BasedOn="{StaticResource TiltCard}">
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!-- 左侧导航栏                              -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="0,0,1,0"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="24,24,24,32">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="12" ClipToBounds="True">
                            <Image Source="pack://application:,,,/default_avatar.png"
                                   Width="40" Height="40" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="背水对战平台" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="BEISHUI" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="{StaticResource FontMono}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- 导航菜单（可折叠分组+滚动） -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="16,0">
                    <StackPanel>
                        <Button Style="{StaticResource NavItemStyle}" Click="NavHome_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="首页" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- 游戏 -->
                        <TextBlock Text="— 游戏 —" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                               Margin="4,12,0,4" HorizontalAlignment="Left"/>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavMatch_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7FC;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="快速匹配" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavDuel_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/default_avatar.png"
                                   Width="18" Height="18" Margin="0,0,12,0" Stretch="UniformToFill"/>
                                <TextBlock Text="1v1 对战" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavCreateServer_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="开服务器" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavRoom_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8BD;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="房间大厅" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavServer_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="服务器" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- 社交 -->
                        <TextBlock Text="— 社交 —" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                               Margin="4,12,0,4" HorizontalAlignment="Left"/>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavFriends_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="好友" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavChat_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE90F;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="聊天" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavVoiceCall_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE717;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="语音" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- 数据 -->
                        <TextBlock Text="— 数据 —" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                               Margin="4,12,0,4" HorizontalAlignment="Left"/>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavHistory_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="战绩" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavDemo_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="Demo回放" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- 娱乐 -->
                        <TextBlock Text="— 娱乐 —" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                               Margin="4,12,0,4" HorizontalAlignment="Left"/>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavLeaderboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="排行榜" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavAchievements_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="成就" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavMarket_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BF;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="皮肤市场" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavMatchingQueue_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81E;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="匹配队列" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavMiniGames_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7C1;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="小游戏" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavWelfare_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="❤️" FontSize="16" Margin="0,0,12,0"/>
                                <TextBlock Text="背水公益" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- 系统 -->
                        <TextBlock Text="— 系统 —" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                               Margin="4,12,0,4" HorizontalAlignment="Left"/>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavScreenShare_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE912;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="屏幕分享" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavBroadcast_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="广播" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavItemStyle}" Click="NavSettings_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock Text="设置" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- 用户信息 -->
                <Border Grid.Row="2" Margin="16,16,16,24"
                        Background="{StaticResource BgElevatedBrush}"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40"
                                CornerRadius="20" Background="{StaticResource PrimaryBrush}"
                                ClipToBounds="True">
                            <Grid>
                                <TextBlock x:Name="txtUserInitial" Text="D"
                                           Foreground="{StaticResource BgDeepBrush}"
                                           FontWeight="Bold" FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Image x:Name="imgUserAvatar" Width="40" Height="40"
                                       Stretch="UniformToFill" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="txtUsername" Text="DemoUser"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="在线" FontSize="11"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="&#xE7E8;"
                                FontFamily="Segoe Fluent Icons"
                                Style="{StaticResource WindowControlBtn}"
                                Click="Logout_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!-- 主内容区                                -->
        <!-- ═══════════════════════════════════════ -->
        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True"
              Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏（独立于 contentArea，不被 WebView2 覆盖） -->
            <Grid Grid.Row="0" Height="64" Margin="24,0"
                  Background="{StaticResource BgDeepBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="txtPageTitle" Text="首页"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Border Background="{StaticResource PrimaryBrush}"
                            CornerRadius="{StaticResource RadiusFull}"
                            Padding="8,4" Margin="16,0,0,0" Width="76">
                        <TextBlock x:Name="txtOnlineCount" Text="1,234 在线"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource BgDeepBrush}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource WindowControlBtn}"
                            Content="&#xE921;" FontFamily="Segoe Fluent Icons"
                            Click="Minimize_Click"/>
                    <Button Style="{StaticResource WindowControlBtn}"
                            Content="&#xE739;" FontFamily="Segoe Fluent Icons"
                            Click="Maximize_Click"/>
                    <Button Style="{StaticResource WindowControlBtn}"
                            Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- 内容区（WebView2 插入此 Grid，不含标题栏按钮） -->
            <Grid x:Name="contentArea" Grid.Row="1" Background="{StaticResource BgDeepBrush}"
                  SnapsToDevicePixels="True" UseLayoutRounding="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 反作弊封锁横幅（全局可见 - 自定义平台封锁徽标） -->
                <Border x:Name="banBlockedBanner" Grid.Row="0"
                    Background="#7F1D1D" BorderBrush="{StaticResource DangerBrush}" BorderThickness="2"
                    CornerRadius="{StaticResource RadiusMedium}" Padding="16,10"
                    Margin="24,0,24,0" Visibility="Collapsed"
                    SnapsToDevicePixels="True" UseLayoutRounding="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="0"
                                      Opacity="0.5" Color="#EF4444"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="30" Height="30"
                            CornerRadius="15" Background="{StaticResource DangerBrush}"
                            Margin="0,0,12,0" BorderThickness="2" BorderBrush="#FCA5A5">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons"
                                   FontSize="16" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1" x:Name="txtBlockedBanner"
                               Text="反作弊系统已封锁 - 游戏入口已全部关闭"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#FCA5A5" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="查看详情"
                            Style="{StaticResource BtnGhost}" Height="32"
                            FontSize="12" Padding="12,0"
                            Foreground="#FCA5A5" BorderBrush="{StaticResource DangerBrush}"
                            Click="AntiCheatDetail_Click"/>
                    </Grid>
                </Border>

                <!-- 内容滚动区 -->
                <ScrollViewer Grid.Row="1" Margin="24,0,24,24"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                    <Grid x:Name="contentGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 数据概览卡片（点击打开详情） -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Style="{StaticResource Card3DHover}" Width="200" Height="100" Margin="0,0,16,0"
                                Cursor="Hand" MouseLeftButtonDown="OpenStats_Click">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="今日场次" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="12" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card3DHover}" Width="200" Height="100" Margin="0,0,16,0"
                                Cursor="Hand" MouseLeftButtonDown="OpenStats_Click">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="胜率" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="67%" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card3DHover}" Width="200" Height="100" Margin="0,0,16,0"
                                Cursor="Hand" MouseLeftButtonDown="OpenStats_Click">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Rating" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="1,847" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource WarningBrush}"
                                           Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card3DHover}" Width="200" Height="100" Margin="0,0,0,0"
                                Cursor="Hand" MouseLeftButtonDown="OpenGameCenter_Click">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="游戏中心" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="🎮" FontSize="32"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 主要内容区 -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 左侧：快速操作 -->
                            <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                <!-- 快速匹配卡片 -->
                                <Border Style="{StaticResource Card3DHover}" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="&#xE7FC;" FontFamily="Segoe Fluent Icons"
                                                   FontSize="32" Foreground="{StaticResource PrimaryBrush}"
                                                   Margin="0,0,0,12"/>
                                            <TextBlock Text="快速匹配" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="立即开始一场5v5竞技对战"
                                                   FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,8,0,0"/>
                                        </StackPanel>
                                        <Button x:Name="btnQuickMatch" Grid.Column="1" Content="开始匹配"
                                            Style="{StaticResource BtnGradient}"
                                            Width="120" Height="48"
                                            VerticalAlignment="Center"
                                            Click="QuickMatch_Click"/>
                                    </Grid>
                                </Border>

                                <!-- 创建房间卡片 -->
                                <Border Style="{StaticResource Card3DHover}" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="&#xE8BD;" FontFamily="Segoe Fluent Icons"
                                                   FontSize="32" Foreground="{StaticResource AccentBrush}"
                                                   Margin="0,0,0,12"/>
                                            <TextBlock Text="创建房间" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="邀请好友，自定义对战"
                                                   FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,8,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="创建"
                                            Style="{StaticResource BtnCyber}"
                                            Width="120" Height="43"
                                            VerticalAlignment="Center"
                                            Click="CreateRoom_Click"/>
                                    </Grid>
                                </Border>

                                <!-- 最近战绩 -->
                                <Border Style="{StaticResource Card3DHover}">
                                    <StackPanel>
                                        <TextBlock Text="最近战绩" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,16"/>
                                        <ListBox x:Name="lbRecentMatches"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             MouseDoubleClick="RecentMatch_DoubleClick">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ListItemHover}"
                                                        Padding="12" Margin="0,0,0,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Ellipse Grid.Column="0"
                                                                 Style="{StaticResource StatusIndicator}"
                                                                 Fill="{Binding ResultColor}"/>
                                                            <StackPanel Grid.Column="1" Margin="8,0">
                                                                <TextBlock Text="{Binding Map}"
                                                                       FontSize="14"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                <TextBlock Text="{Binding Date}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2"
                                                                   Text="{Binding Score}"
                                                                   FontSize="16" FontWeight="Bold"
                                                                   Foreground="{Binding ResultColor}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- 右侧：反作弊状态 + 公告 -->
                            <StackPanel Grid.Column="1" Margin="0,0,0,0">
                                <!-- 反作弊状态 -->
                                <Border Style="{StaticResource Card3DHover}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                            <Border Style="{StaticResource PillBadgeActive}" Padding="8,4">
                                                <TextBlock Text="运行正常" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                            </Border>
                                            <TextBlock Text="反作弊系统" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="16,0,0,8">
                                            <Ellipse x:Name="antiCheatStatus" Width="8" Height="8"
                                                 Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>
                                            <TextBlock x:Name="txtAntiCheatStatusDisplay" Text="运行正常" FontSize="14"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="txtAntiCheatLastScan" Text="上次扫描: --"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="16,0,0,0"/>
                                        <Button Content="查看详情" Style="{StaticResource BtnGhost}"
                                            Margin="0,16,0,0" Height="46"
                                            Click="AntiCheatDetail_Click"/>
                                    </StackPanel>
                                </Border>

                                <!-- 系统公告 -->
                                <Border Style="{StaticResource Card3DHover}">
                                    <StackPanel>
                                        <TextBlock Text="&#xE90A;" FontFamily="Segoe Fluent Icons"
                                               FontSize="24" Foreground="{StaticResource WarningBrush}"
                                               Margin="0,0,0,12"/>
                                        <TextBlock Text="系统公告" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,12"/>
                                        <TextBlock Text="背水对战平台 v2.0 正式发布！全新UI设计，更流畅的动画体验，更强大的反作弊系统。"
                                               FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                        <Border Style="{StaticResource PillBadgeWarning}" Margin="0,12,0,0" HorizontalAlignment="Left">
                                            <TextBlock Text="2026-04-26" FontSize="11"
                                                   Foreground="{StaticResource WarningBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- 系统状态 -->
                                <Border Style="{StaticResource Card3DHover}" Margin="0,16,0,16">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="&#xE790;" FontFamily="Segoe Fluent Icons"
                                                   FontSize="20" Foreground="{StaticResource InfoBrush}"
                                                   Margin="0,0,8,0"/>
                                            <TextBlock Text="系统状态" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="运行时间" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="txtUptime" Grid.Row="0" Grid.Column="1"
                                                   Text="0h 0m" FontSize="12" FontFamily="{StaticResource FontMono}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="CS2 状态" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1"
                                                   x:Name="txtCs2Status" Text="未检测到"
                                                   FontSize="12" Margin="0,4,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="反作弊" FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,4,0,0"/>
                                            <Border Style="{StaticResource PillBadgeActive}" HorizontalAlignment="Right" Margin="0,2,0,0">
                                                <TextBlock x:Name="txtAntiCheatInfo" Text="运行中"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- 页脚：平台信息 -->
                        <Border Grid.Row="2" Background="{StaticResource BgCardBrush}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="16,12" Margin="0,24,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                       Text="背水对战平台 v2.0 Aurora · 版权归属背水工作室"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock x:Name="txtCpuStatus" Grid.Column="1"
                                       Text="" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="{StaticResource FontMono}" Margin="0,0,16,0"/>
                                <TextBlock x:Name="txtMemStatus" Grid.Column="2"
                                       Text="" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="{StaticResource FontMono}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <!-- 全局加载遮罩层 -->
                <Border x:Name="loadingOverlay" Visibility="Collapsed"
                    Background="#CC0A1A10" SnapsToDevicePixels="True"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Grid.RowSpan="2" Panel.ZIndex="100">
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 主图标容器 -->
                        <Border Grid.Row="0" x:Name="loadingIconContainer"
                            Width="72" Height="72" CornerRadius="20"
                            Background="{StaticResource CardGradientBrush}"
                            BorderBrush="{StaticResource BorderPrimaryBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border x:Name="loadingSpinner"
                                Width="48" Height="48" CornerRadius="24"
                                BorderThickness="3"
                                BorderBrush="{StaticResource PrimaryBrush}"
                                Background="Transparent"
                                RenderTransformOrigin="0.5,0.5"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Border>

                        <!-- 加载文字 -->
                        <TextBlock Grid.Row="1" x:Name="txtLoadingMessage"
                               Text="加载中..."
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <!-- 加载子状态 -->
                        <TextBlock Grid.Row="2" x:Name="txtLoadingSub"
                               Text=""
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>

                        <!-- 进度条 -->
                        <Border Grid.Row="3" Height="3" CornerRadius="2"
                            Background="{StaticResource BgElevatedBrush}"
                            HorizontalAlignment="Stretch"
                            Margin="20,0">
                            <Border x:Name="loadingProgressBar" Width="0"
                                Height="3" CornerRadius="2"
                                Background="{StaticResource PrimaryBrush}"
                                HorizontalAlignment="Left">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0"
                                                  Opacity="0.5" Color="#4ADE80"/>
                                </Border.Effect>
                            </Border>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
