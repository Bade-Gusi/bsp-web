<Window x:Class="BeiShuiCS2.BlockedDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="封锁详情"
        Width="560" Height="613"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"/>

        <!-- 标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                    Background="{StaticResource DangerBrush}" Margin="0,0,16,0">
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons"
                           FontSize="22" Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="反作弊封锁详情" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="游戏入口已被全部关闭" FontSize="13"
                           Foreground="{StaticResource DangerBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="2" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}" Click="Close_Click"/>
        </Grid>

        <!-- 封锁信息卡片 -->
        <Border Grid.Row="1" Background="#1A0A0A"
                BorderBrush="{StaticResource DangerBrush}" BorderThickness="1"
                CornerRadius="{StaticResource RadiusMedium}" Padding="20,16"
                Margin="0,0,0,16">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="封锁状态" FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}" Width="100"/>
                    <Border Grid.Column="1" Background="{StaticResource DangerBrush}"
                            CornerRadius="4" Padding="8,2" Width="Auto" HorizontalAlignment="Left">
                        <TextBlock Text="永久封锁" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Border>
                </Grid>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="封锁时间" FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}" Width="100"/>
                    <TextBlock Grid.Column="1" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}">
                        <TextBlock x:Name="txtBlockTime" Text="2026-04-27 12:00:00"/>
                    </TextBlock>
                </Grid>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="封锁原因" FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}" Width="100"/>
                    <TextBlock Grid.Column="1" x:Name="txtBlockReason" FontSize="13"
                               Foreground="#FCA5A5" Text="检测到异常程序注入" TextWrapping="Wrap"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="建议操作" FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}" Width="100"
                               VerticalAlignment="Top"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="1. 关闭所有可能影响反作弊的程序" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="2. 重新启动背水对战平台" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="3. 如问题持续，联系客服 support@beishui.com" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 详细日志 -->
        <TextBlock Grid.Row="2" Text="检测日志" FontSize="14" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="logPanel">
                    <TextBlock x:Name="txtLog" Text="反作弊系统扫描日志：&#x0a;&#x0a;2026-04-27 12:00:00 [错误] 内存扫描异常&#x0a;2026-04-27 11:59:45 [警告] 检测到未知模块注入&#x0a;2026-04-27 11:59:30 [信息] 开始定期安全检查"
                               FontSize="12" FontFamily="{StaticResource FontMono}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 按钮 -->
        <Button Grid.Row="4" Content="我知道了"
                Style="{StaticResource BtnDanger}"
                Width="160" Height="42" FontSize="14"
                HorizontalAlignment="Center" Margin="0,20,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>
