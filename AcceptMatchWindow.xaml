<Window x:Class="BeiShuiCS2.AcceptMatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="接受匹配"
        Width="580" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="4"/>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="⚔ 匹配成功！" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="请确认是否接受对战"
                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- 信息内容 -->
        <Border Grid.Row="2" CornerRadius="{StaticResource RadiusMedium}"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="1" Padding="24">
            <StackPanel>

                <!-- VS 区域 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- 我方 -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <Border Width="56" Height="56" CornerRadius="28"
                                Background="{StaticResource PrimaryGradientBrush}">
                            <TextBlock x:Name="txtMyNameInitial" Text="我"
                                       FontSize="24" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="txtMyName" Text="等待中"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,2"/>
                        <TextBlock x:Name="txtMyMMR" Text=""
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <!-- VS -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="20,0">
                        <TextBlock Text="VS" FontSize="28" FontWeight="Black"
                                   Foreground="{StaticResource WarningBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtMap" Text="de_dust2"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <!-- 对手 -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <Border Width="56" Height="56" CornerRadius="28"
                                Background="{StaticResource AccentGradientBrush}">
                            <TextBlock x:Name="txtOpponentInitial" Text="?"
                                       FontSize="24" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="txtOpponentName" Text="对手"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,2"/>
                        <TextBlock x:Name="txtOpponentMMR" Text=""
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Separator Background="{StaticResource BorderPrimaryBrush}" Margin="0,0,0,16"/>

                <!-- 比赛信息 -->
                <TextBlock Text="比赛信息" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                <Grid Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="模式" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtMode" Text="竞技 (5v5)"
                               FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="地图" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="16,0,8,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" x:Name="txtMapName" Text="炼狱小镇"
                               FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="平均MMR" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtAvgMMR" Text="1200"
                               FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="段位" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="16,0,8,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" x:Name="txtAvgRank" Text="黄金"
                               FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="我的胜场" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,6"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtMyWins" Text="--"
                               FontSize="12" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="对手胜场" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="16,0,8,6"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" x:Name="txtOpponentWins" Text="--"
                               FontSize="12" Foreground="{StaticResource WarningBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="我的胜率" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,6"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtMyWinRate" Text="--"
                               FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="对手胜率" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="16,0,8,6"/>
                    <TextBlock Grid.Row="3" Grid.Column="3" x:Name="txtOpponentWinRate" Text="--"
                               FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="总场次" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtMyGames" Text="--"
                               FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="总场次" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" Margin="16,0,8,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="3" x:Name="txtOpponentGames" Text="--"
                               FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                </Grid>

                <!-- 倒计时 -->
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,0">
                    <TextBlock Text="自动拒绝" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtCountdown" Text="15"
                               FontSize="36" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               FontFamily="{StaticResource FontMono}"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- 按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="拒绝" Style="{StaticResource BtnGhost}"
                    Width="160" Height="48" FontSize="16"
                    Margin="0,0,16,0" Click="Cancel_Click"/>
            <Button Content="✓ 接受匹配" Style="{StaticResource BtnPrimary}"
                    Width="160" Height="48" FontSize="16"
                    Click="Accept_Click"/>
        </StackPanel>
    </Grid>
</Window>
