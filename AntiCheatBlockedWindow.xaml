<Window x:Class="BeiShuiCS2.AntiCheatBlockedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="已封锁"
        Width="480" Height="502"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">
    <Grid Margin="36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"/>

        <!-- 封锁徽标（平台专用） -->
        <Border Grid.Row="0" Width="64" Height="64" CornerRadius="32"
                Background="{StaticResource DangerBrush}" Margin="0,0,0,16"
                HorizontalAlignment="Center"
                BorderThickness="3" BorderBrush="#FCA5A5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                                  Opacity="0.5" Color="#EF4444"/>
            </Border.Effect>
            <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons"
                       FontSize="32" Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14,12,0,0"/>
        </Border>

        <!-- 标题 -->
        <TextBlock Grid.Row="1" Text="反作弊系统已封锁"
                   FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource DangerBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,12"/>

        <!-- 说明 -->
        <Border Grid.Row="2" Background="#1A0A0A"
                CornerRadius="{StaticResource RadiusMedium}"
                Padding="20,16" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="检测到您的系统中存在可疑程序或异常行为，反作弊系统已自动封锁所有游戏入口。"
                           FontSize="14" Foreground="#FCA5A5"
                           TextWrapping="Wrap" Margin="0,0,0,12"/>
                <TextBlock Text="建议操作："
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="1. 关闭所有可能影响反作弊的程序（如修改器、注入工具等）"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="16,0,0,4"/>
                <TextBlock Text="2. 重新启动背水对战平台"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="16,0,0,4"/>
                <TextBlock Text="3. 如问题持续，请联系客服 support@beishui.com"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 按钮 -->
        <Button Grid.Row="4" Content="我知道了"
                Style="{StaticResource BtnDanger}"
                Width="160" Height="44" FontSize="15"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Click="OK_Click"/>
    </Grid>
</Window>
