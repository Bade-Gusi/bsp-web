<Window x:Class="BeiShuiCS2.MemoryGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="记忆游戏" 
        Width="600" Height="685"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="记忆游戏" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    Click="Close_Click"/>
        </Grid>

        <!-- 分数和时间 -->
        <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0,60,0,0">
            <StackPanel Orientation="Horizontal">
                <Border Background="{StaticResource BgElevatedBrush}"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Padding="16,8" Margin="0,0,12,0">
                    <TextBlock x:Name="txtScore" Text="得分: 0" FontSize="16"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>
                <Border Background="{StaticResource BgElevatedBrush}"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Padding="16,8">
                    <TextBlock x:Name="txtTime" Text="时间: 60" FontSize="16"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- 游戏区域 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,20">
            <UniformGrid x:Name="gridGame" Rows="4" Columns="4" Margin="20">
                <!-- 动态生成卡片 -->
            </UniformGrid>
        </Border>

        <!-- 按钮 -->
        <Button x:Name="btnRestart" Content="重新开始" 
                Style="{StaticResource BtnPrimary}"
                Height="48" FontSize="15" Margin="0,7,0,42"
                Click="BtnRestart_Click"/>
    </Grid>
</Window>
