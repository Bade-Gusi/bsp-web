<Window x:Class="BeiShuiCS2.BroadcastServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="广播服务器地址" Width="420" Height="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid>
        <Border Style="{StaticResource GlassCardPremium}" Margin="20">
            <StackPanel Margin="16">
                <!-- 标题 -->
                <StackPanel Margin="0,8,0,20">
                    <TextBlock Text="广播服务器地址" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="输入管理密码后可将服务器地址推送到所有在线用户"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 密码输入 -->
                <TextBlock x:Name="lblPassword" Text="管理密码" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="txtPassword"
                             Background="{StaticResource BgElevatedBrush}"
                             BorderBrush="{StaticResource BorderPrimaryBrush}"
                             BorderThickness="1"
                             Padding="12,10" FontSize="14"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             CaretBrush="{StaticResource PrimaryBrush}"
                             PasswordChanged="Password_Changed"/>

                <!-- 服务器地址输入（初始隐藏） -->
                <StackPanel x:Name="panelServer" Visibility="Collapsed" Margin="0,16,0,0">
                    <TextBlock Text="服务器地址" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtServerAddress"
                             Background="{StaticResource BgElevatedBrush}"
                             BorderBrush="{StaticResource BorderPrimaryBrush}"
                             BorderThickness="1"
                             Padding="12,10" FontSize="14"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             CaretBrush="{StaticResource PrimaryBrush}"
                             Text="1.2.3.4:27015"/>

                    <!-- 广播按钮 -->
                    <Button x:Name="btnBroadcast" Content="广播给所有在线用户"
                            Style="{StaticResource BtnGradient}"
                            Height="44" FontSize="14"
                            Margin="0,20,0,0"
                            Click="BtnBroadcast_Click"/>

                    <!-- 状态提示 -->
                    <TextBlock x:Name="txtStatus" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- 密码错误提示 -->
                <TextBlock x:Name="txtError" FontSize="12"
                           Foreground="{StaticResource DangerBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- 关闭按钮 -->
        <Button Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                Style="{StaticResource WindowControlBtn}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,8,0" Click="Close_Click"/>
    </Grid>
</Window>
