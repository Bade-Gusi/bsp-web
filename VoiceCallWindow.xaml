<Window x:Class="BeiShuiCS2.VoiceCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="语音通话"
        Width="720" Height="561"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Topmost="False"
        Background="Transparent"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="3"/>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Width="40" Height="40" CornerRadius="20"
                        Background="{StaticResource PrimaryGradientBrush}" Margin="0,0,12,0">
                    <TextBlock Text="&#xE717;" FontFamily="Segoe Fluent Icons"
                               FontSize="18" Foreground="{StaticResource BgDeepBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="语音通话" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="dotCallStatus" Width="8" Height="8"
                                 Fill="{StaticResource PrimaryBrush}" Margin="0,0,6,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtCallStatus" Text="通话中 · 00:00"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- 最小化/关闭按钮 -->
            <Button Grid.Column="1" Content="&#xE921;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}" Click="Minimize_Click" Margin="0,0,4,0"/>
            <Button Grid.Column="2" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}" Click="Close_Click"/>
        </Grid>

        <!-- 参与者列表 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="participantsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10" Padding="14,12"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 头像 -->
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                                            Background="{StaticResource PrimaryGradientBrush}">
                                        <TextBlock Text="{Binding Initial}"
                                                   Foreground="{StaticResource BgDeepBrush}"
                                                   FontWeight="Bold" FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 名称 + 状态 -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <Border Background="{StaticResource InfoBrush}"
                                                    CornerRadius="{StaticResource RadiusFull}"
                                                    Padding="6,2" Margin="8,0,0,0"
                                                    Visibility="{Binding IsHost, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="主持人" FontSize="10"
                                                           Foreground="{StaticResource BgDeepBrush}"/>
                                            </Border>
                                            <Border x:Name="tagSpeaking" Background="{StaticResource PrimaryBrush}"
                                                    CornerRadius="{StaticResource RadiusFull}"
                                                    Padding="6,2" Margin="8,0,0,0"
                                                    Visibility="{Binding IsSpeaking, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="说话中" FontSize="10"
                                                           Foreground="{StaticResource BgDeepBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Status}" FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- 音量指示条 -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Border Width="40" Height="4" CornerRadius="2"
                                                Background="{StaticResource BgHoverBrush}" Margin="0,0,8,0">
                                            <Border Width="{Binding VolumePercent}"
                                                    HorizontalAlignment="Left"
                                                    Background="{StaticResource PrimaryBrush}"
                                                    CornerRadius="2"/>
                                        </Border>
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{Binding VolumeColor}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 底部控制栏 -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：音频设备选择 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox x:Name="cmbMicDevice" Width="140" Height="32"
                              Background="{StaticResource BgElevatedBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="{StaticResource BorderPrimaryBrush}"
                              FontSize="12"
                              SelectionChanged="MicDevice_Changed">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="12"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox x:Name="cmbSpeakerDevice" Width="140" Height="32" Margin="8,0,0,0"
                              Background="{StaticResource BgElevatedBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="{StaticResource BorderPrimaryBrush}"
                              FontSize="12"
                              SelectionChanged="SpeakerDevice_Changed">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="12"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- 右侧：控制按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 音量滑块 -->
                    <Border Background="{StaticResource BgElevatedBrush}"
                            CornerRadius="{StaticResource RadiusFull}"
                            Padding="10,6" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE995;" FontFamily="Segoe Fluent Icons"
                                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Slider x:Name="volumeSlider" Width="80" Minimum="0" Maximum="100" Value="75"
                                    Style="{StaticResource {x:Type Slider}}"
                                    ValueChanged="Volume_Changed" Height="20"/>
                        </StackPanel>
                    </Border>

                    <!-- 静音按钮 -->
                    <Button x:Name="btnMute" Style="{StaticResource BtnGhost}"
                            Width="44" Height="44" Padding="0" Margin="0,0,8,0"
                            Click="Mute_Click" FontSize="20"
                            Content="&#xEC34;" FontFamily="Segoe Fluent Icons">
                        <Button.ToolTip>切换静音</Button.ToolTip>
                    </Button>

                    <!-- 分享屏幕按钮 -->
                    <Button x:Name="btnShareScreen" Style="{StaticResource BtnNeumorph}"
                            Width="44" Height="44" Padding="0" Margin="0,0,8,0"
                            Click="ShareScreen_Click" FontSize="18"
                            Content="&#xE912;" FontFamily="Segoe Fluent Icons">
                        <Button.ToolTip>屏幕分享</Button.ToolTip>
                    </Button>

                    <!-- 挂断按钮 -->
                    <Button x:Name="btnEndCall" Style="{StaticResource BtnDanger}"
                            Width="48" Height="48" Padding="0"
                            Click="EndCall_Click" FontSize="20"
                            Content="&#xE98A;" FontFamily="Segoe Fluent Icons">
                        <Button.ToolTip>挂断</Button.ToolTip>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <TextBlock x:Name="txtConnectionInfo" Grid.Row="2"
                   Text="连接信息: UDP · 延迟 12ms · 丢包率 0.0%"
                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                   HorizontalAlignment="Left" Margin="18,0,0,5" VerticalAlignment="Bottom"/>
    </Grid>
</Window>
