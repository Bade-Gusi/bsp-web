<Window x:Class="BeiShuiCS2.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="注册账号"
        Width="480" Height="1092"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Margin="0,0,0,202"/>
        <!-- 背景光效 -->
        <Ellipse Width="400" Height="400" Fill="{StaticResource PrimaryBrush}"
                 Opacity="0.04" HorizontalAlignment="Center" VerticalAlignment="Top"
                 Margin="0,-100,0,0"/>

        <Grid Margin="48,40,48,48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 关闭按钮 -->
            <Button Grid.Row="0" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Click="Close_Click"/>

            <!-- 标题 -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,32">
                <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons"
                           FontSize="40" Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="注册背水账号" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="创建你的账号，开始游戏之旅" FontSize="13"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 表单 -->
            <StackPanel Grid.Row="2" Margin="0,8,0,0">
                <!-- 用户名 -->
                <TextBlock Text="用户名" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="txtUsername" Style="{StaticResource FrostedInput}"
                         Margin="0,0,0,16" Padding="12,10"
                         FontSize="14" CaretBrush="{StaticResource PrimaryBrush}"
                         MaxLength="20"/>

                <!-- 邮箱 -->
                <TextBlock Text="邮箱地址" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="txtEmail" Style="{StaticResource FrostedInput}"
                         Margin="0,0,0,16" Padding="12,10"
                         FontSize="14" CaretBrush="{StaticResource PrimaryBrush}"/>

                <!-- 密码 -->
                <TextBlock Text="密码" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <Border Background="{StaticResource GlassGradientBrush}"
                        CornerRadius="{StaticResource RadiusSmall}"
                        BorderBrush="{StaticResource BorderPrimaryBrush}"
                        BorderThickness="1" Margin="0,0,0,16">
                    <PasswordBox x:Name="txtPassword" Background="Transparent" BorderThickness="0"
                                 Padding="12,10" Foreground="{StaticResource TextPrimaryBrush}"
                                 FontSize="14" CaretBrush="{StaticResource PrimaryBrush}"/>
                </Border>

                <!-- 确认密码 -->
                <TextBlock Text="确认密码" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <Border Background="{StaticResource GlassGradientBrush}"
                        CornerRadius="{StaticResource RadiusSmall}"
                        BorderBrush="{StaticResource BorderPrimaryBrush}"
                        BorderThickness="1" Margin="0,0,0,16">
                    <PasswordBox x:Name="txtConfirmPassword" Background="Transparent" BorderThickness="0"
                                 Padding="12,10" Foreground="{StaticResource TextPrimaryBrush}"
                                 FontSize="14" CaretBrush="{StaticResource PrimaryBrush}"/>
                </Border>

                <!-- 手机号 -->
                <TextBlock Text="手机号" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="txtPhone" Style="{StaticResource FrostedInput}"
                         Margin="0,0,0,16" Padding="12,10"
                         FontSize="14" CaretBrush="{StaticResource PrimaryBrush}"
                         MaxLength="11"/>

                <!-- Steam ID（选填）-->
                <TextBlock Text="Steam ID（选填）" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="txtSteamId" Style="{StaticResource FrostedInput}"
                         Margin="0,0,0,16" Padding="12,10"
                         FontSize="14" CaretBrush="{StaticResource PrimaryBrush}"
                         MaxLength="17"/>

                <!-- 验证码 -->
                <TextBlock Text="验证码" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtCode" Style="{StaticResource FrostedInput}"
                             MaxLength="6" Grid.Column="0"/>
                    <Button x:Name="btnSendCode" Grid.Column="1" Content="发送验证码"
                            Style="{StaticResource BtnGhost}" Margin="12,0,-12,0" Click="SendCode_Click"/>
                </Grid>

                <!-- 错误提示 -->
                <TextBlock x:Name="txtError" Foreground="#F43F5E" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed"/>

                <!-- 注册按钮 -->
                <Button x:Name="btnRegister" Content="创建账号"
                        Style="{StaticResource BtnGradient}"
                        Height="50" FontSize="16"
                        Click="BtnRegister_Click"/>

                <!-- 用户协议 -->
                <CheckBox x:Name="chkAgree" Margin="0,8,0,0"
                          Foreground="{StaticResource TextMutedBrush}"
                          FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="我已阅读并同意" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                        <Button Content="《用户协议》" Style="{StaticResource BtnLink}"
                                FontSize="12" Padding="2,0"
                                Click="ViewAgreement_Click"/>
                        <TextBlock Text="和" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                        <Button Content="《隐私政策》" Style="{StaticResource BtnLink}"
                                FontSize="12" Padding="2,0"
                                Click="ViewPrivacy_Click"/>
                    </StackPanel>
                </CheckBox>

                <!-- 已有账号 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,16,0,0">
                    <TextBlock Text="已有账号？" FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <Button Content="立即登录" Style="{StaticResource BtnLink}"
                            Click="GoLogin_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
