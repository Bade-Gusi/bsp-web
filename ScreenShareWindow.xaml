<Window x:Class="BeiShuiCS2.ScreenShareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="屏幕分享"
        Width="1045" Height="739"
        MinWidth="600" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Topmost="False"
        Background="Transparent"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 粒子画布 -->
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="3"/>

        <!-- ── 标题栏 ── -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Width="40" Height="40" CornerRadius="20"
                        Background="{StaticResource PrimaryGradientBrush}" Margin="0,0,12,0">
                    <TextBlock Text="&#xE912;" FontFamily="Segoe Fluent Icons"
                               FontSize="18" Foreground="{StaticResource BgDeepBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="屏幕分享" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="dotStreamStatus" Width="8" Height="8"
                                 Fill="{StaticResource PrimaryBrush}" Margin="0,0,6,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtStreamStatus" Text="正在分享 · 30 FPS"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1" Content="&#xE921;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}" Click="Minimize_Click" Margin="0,0,4,0"/>
            <Button Grid.Column="2" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}" Click="Close_Click"/>
        </Grid>

        <!-- ── 主内容区 ── -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：屏幕预览 -->
            <Border Grid.Column="0" Background="{StaticResource BgDeepBrush}"
                    CornerRadius="{StaticResource RadiusLarge}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}" BorderThickness="1"
                    Margin="0,0,16,0" ClipToBounds="True">
                <Grid>
                    <!-- 真实屏幕预览 -->
                    <Border Background="{StaticResource BgCardBrush}">
                        <Grid>
                            <Image x:Name="previewImage" Stretch="Uniform"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="8"/>
                            <Border VerticalAlignment="Bottom" Background="#CC0A1510" Padding="8,4">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource PrimaryBrush}"
                                             Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtPreviewFps" Text="正在广播 · 30 FPS"
                                               FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 分享中的水印效果 -->
                    <Border Background="Transparent" IsHitTestVisible="False"
                            Opacity="0.15">
                        <TextBlock Text="&#xE912; 背水对战平台" FontSize="48" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- 右侧：控制面板 -->
            <Border Grid.Column="1" Background="{StaticResource BgCardBrush}"
                    CornerRadius="{StaticResource RadiusLarge}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}" BorderThickness="1"
                    Padding="16">
                <StackPanel>
                    <!-- 屏幕选择 -->
                    <TextBlock Text="屏幕选择" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbScreen" Height="32"
                              Background="{StaticResource BgElevatedBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="{StaticResource BorderPrimaryBrush}"
                              FontSize="12" Margin="0,0,0,16">
                        <ComboBoxItem Content="屏幕 1 (主显示器)" IsSelected="True" Tag="0"/>
                        <ComboBoxItem Content="屏幕 2 (副显示器)" Tag="1"/>
                        <ComboBoxItem Content="所有屏幕" Tag="all"/>
                    </ComboBox>

                    <!-- 画质选择 -->
                    <TextBlock Text="画质" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbQuality" Height="32"
                              Background="{StaticResource BgElevatedBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="{StaticResource BorderPrimaryBrush}"
                              FontSize="12" Margin="0,0,0,16">
                        <ComboBoxItem Content="高画质 (1080p 60FPS)" Tag="high"/>
                        <ComboBoxItem Content="中画质 (720p 30FPS)" Tag="medium" IsSelected="True"/>
                        <ComboBoxItem Content="低画质 (480p 15FPS)" Tag="low"/>
                    </ComboBox>

                    <!-- 帧率显示 -->
                    <Border Background="{StaticResource BgElevatedBrush}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="12" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="当前帧率" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="码率: ~2.5 Mbps" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" x:Name="txtFps"
                                       Text="30" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontFamily="{StaticResource FontMono}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 开始/停止分享 -->
                    <Button x:Name="btnToggleShare" Content="&#xE98A; 停止分享"
                            Style="{StaticResource BtnDanger}" Height="44"
                            FontSize="15" FontWeight="Bold" Margin="0,0,0,12"
                            Click="ToggleShare_Click"/>

                    <Button x:Name="btnPauseShare" Content="&#xE769; 暂停分享"
                            Style="{StaticResource BtnGhost}" Height="40"
                            FontSize="13" Margin="0,0,0,16"
                            Click="PauseShare_Click"/>

                    <!-- 分隔线 -->
                    <Border Height="1" Background="{StaticResource BorderPrimaryBrush}"
                            Margin="0,0,0,16"/>

                    <!-- 观看者列表 -->
                    <TextBlock Text="观看者" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <ItemsControl x:Name="viewersList" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,0,0,4"
                                        Background="{StaticResource BgElevatedBrush}"
                                        CornerRadius="{StaticResource RadiusSmall}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{Binding DotColor}"
                                                 Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 邀请更多 -->
                    <Button Content="&#xE8FD; 邀请更多" Style="{StaticResource BtnNeumorph}"
                            Height="49" FontSize="13" Click="Invite_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── 底部状态栏 ── -->
        <Border Grid.Row="2" Background="{StaticResource BgCardBrush}"
                CornerRadius="{StaticResource RadiusLarge}"
                BorderBrush="{StaticResource BorderPrimaryBrush}" BorderThickness="1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="txtStreamInfo" Text="编码: H.264 · 分辨率: 1280×720"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="txtViewerCount" Text=" · 2 人正在观看"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               Margin="8,0,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="txtUptime" Text="已分享 02:34"
                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
