<Window x:Class="BeiShuiCS2.MatchDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:e="clr-namespace:BeiShuiCS2"
        Title="对局详情" 
        Width="600" Height="472"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">


    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="对局详情" Style="{StaticResource PageHeader}"/>
            <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    Click="Close_Click"/>
        </Grid>

        <!-- 比分 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="反恐精英" FontSize="14" FontWeight="SemiBold"
                               Foreground="#3B82F6" HorizontalAlignment="Center"/>
                    <TextBlock Text="16" FontSize="36" FontWeight="Bold"
                               Foreground="#3B82F6" HorizontalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text=":" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="16,0"/>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="恐怖分子" FontSize="14" FontWeight="SemiBold"
                               Foreground="#EF4444" HorizontalAlignment="Center"/>
                    <TextBlock Text="14" FontSize="36" FontWeight="Bold"
                               Foreground="#EF4444" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 详细信息 -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="地图" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="de_dust2" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource FontMono}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="模式" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="竞技模式" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="时间" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="2026-04-26 10:30" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="时长" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="45:32" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Button Grid.Row="3" Content="重新连接" Style="{StaticResource BtnPrimary}"
                Width="160" Height="48" Margin="0,24,0,0"
                HorizontalAlignment="Center" Click="Reconnect_Click">
            <Button.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                  Opacity="0.4" Color="{StaticResource PrimaryColor}"/>
            </Button.Effect>
        </Button>
    </Grid>
</Window>

