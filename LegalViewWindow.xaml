<Window x:Class="BeiShuiCS2.LegalViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="用户协议"
        Width="700" Height="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="3"/>

        <StackPanel Grid.Row="0" Margin="0,0,0,12" HorizontalAlignment="Center">
            <TextBlock x:Name="txtTitle" Text="用户协议"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="txtVersion" Text="V1.0 · 2026年5月11日"
                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" CornerRadius="{StaticResource RadiusMedium}"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="1" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="txtContent" Text=""
                           FontSize="15" Foreground="{StaticResource TextPrimaryBrush}"
                           LineHeight="28" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2" Content="关闭"
                Style="{StaticResource BtnPrimary}"
                Width="120" Height="40" FontSize="14"
                Margin="0,12,0,0" HorizontalAlignment="Center"
                Click="Close_Click"/>
    </Grid>
</Window>
