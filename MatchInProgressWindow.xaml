<Window x:Class="BeiShuiCS2.MatchInProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="比赛中"
        Width="900" Height="700"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="3"/>

        <!-- 顶部标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Width="36" Height="36" CornerRadius="10"
                        Background="{StaticResource DangerBrush}" Margin="0,0,10,0">
                    <TextBlock Text="CT" FontSize="13" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtTeamName" Text="Team A" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="txtMatchMap" Text="de_inferno · 竞技模式"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- 比分 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="txtCtScore" Text="0" FontSize="42" FontWeight="Black"
                           Foreground="{StaticResource PrimaryBrush}"
                           FontFamily="{StaticResource FontMono}"/>
                <TextBlock Text=":" FontSize="36" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="16,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtTSscore" Text="0" FontSize="42" FontWeight="Black"
                           Foreground="{StaticResource WarningBrush}"
                           FontFamily="{StaticResource FontMono}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock x:Name="txtRoundInfo" Text="手枪局"
                           FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="txtMatchTimer" Text="00:00"
                           FontSize="14" FontFamily="{StaticResource FontMono}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 主内容：比分板 -->
        <Border Grid.Row="1" CornerRadius="{StaticResource RadiusMedium}"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- CT 队列表头 -->
                <Grid Grid.Row="0" Background="#1A3A2A" Height="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="1" Text="玩家" VerticalAlignment="Center"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="2" Text="K" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="D" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="A" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="评分" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                </Grid>

                <!-- CT 队列表 -->
                <ItemsControl x:Name="ctPlayerList" Grid.Row="1"
                              Background="Transparent" BorderThickness="0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,6" BorderBrush="{StaticResource BorderPrimaryBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Slot}"
                                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Kills}"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Deaths}"
                                               FontSize="13" Foreground="{StaticResource DangerBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Assists}"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="{Binding Score}"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource WarningBrush}"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- T 队列表头 -->
                <Grid Grid.Row="2" Background="#3A1A1A" Height="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="1" Text="玩家" VerticalAlignment="Center"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Grid.Column="2" Text="K" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="D" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="A" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="评分" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                </Grid>

                <!-- T 队列表 -->
                <ItemsControl x:Name="tPlayerList" Grid.Row="3"
                              Background="Transparent" BorderThickness="0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,6" BorderBrush="{StaticResource BorderPrimaryBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Slot}"
                                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Kills}"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Deaths}"
                                               FontSize="13" Foreground="{StaticResource DangerBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Assists}"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="{Binding Score}"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource WarningBrush}"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- 底部控制栏 -->
        <Border Grid.Row="2" Background="{StaticResource BgElevatedBrush}"
                CornerRadius="{StaticResource RadiusMedium}"
                Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}"
                             Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="比赛中" FontSize="12"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="服务器: " FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="txtServerAddr" Text="127.0.0.1:27015"
                               FontSize="11" FontFamily="{StaticResource FontMono}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="查看战绩" Style="{StaticResource BtnGhost}"
                            Height="41" FontSize="12" Margin="0,0,8,0"
                            Click="ViewMatchResult_Click"/>
                    <Button Content="离开" Style="{StaticResource BtnGhost}"
                            Height="41" FontSize="12" Click="Leave_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
