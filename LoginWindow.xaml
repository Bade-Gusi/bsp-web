<Window x:Class="BeiShuiCS2.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:e="clr-namespace:BeiShuiCS2"
        Title="背水对战平台 - 登录"
        Width="500" Height="834"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Loaded="Window_Loaded" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid>
        <!-- 背景深度渐变 -->
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.25" RadiusX="0.85" RadiusY="0.85">
                <GradientStop Color="#0E1E15" Offset="0"/>
                <GradientStop Color="{StaticResource BgDeepColor}" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <!-- 粒子层 -->
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False"/>

        <!-- 装饰极光光晕（左上&右下） -->
        <Ellipse Width="280" Height="280"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-100,-80,0,0"
                 Fill="{StaticResource PrimaryBrush}" Opacity="0.04"
                 IsHitTestVisible="False"/>
        <Ellipse Width="200" Height="200"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-60,-60"
                 Fill="{StaticResource AccentTealBrush}" Opacity="0.03"
                 IsHitTestVisible="False"/>

        <!-- 主内容区 -->
        <Grid x:Name="contentRoot" VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══════ Logo 区域 ═══════ -->
            <StackPanel x:Name="logoSection" Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,36">
                <Border Width="84" Height="84" CornerRadius="22" Margin="0,0,0,20" ClipToBounds="True"
                        RenderTransformOrigin="0.5,0.5"
                        Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <Image Source="pack://application:,,,/default_avatar.png"
                           Width="84" Height="84" Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="背水对战平台" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="BEISHUI AURORA v2.0" FontSize="11" FontWeight="Light"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"
                           FontFamily="{StaticResource FontMono}"/>
            </StackPanel>

            <!-- ═══════ 登录卡片 ═══════ -->
            <Border x:Name="loginCard" Grid.Row="1" Style="{StaticResource GlassCardPremium}"
                    Margin="0,0,0,20" Padding="24">
                <StackPanel>
                    <!-- 用户名 -->
                    <TextBlock Text="用户名" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <Border x:Name="usernameBorder"
                            Background="{StaticResource GlassGradientBrush}"
                            CornerRadius="{StaticResource RadiusSmall}"
                            BorderBrush="{StaticResource BorderPrimaryBrush}"
                            BorderThickness="1" Margin="0,0,0,20"
                            Height="47">
                        <TextBox x:Name="txtUsername"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="14,12"
                                 FontSize="14"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 CaretBrush="{StaticResource PrimaryBrush}"
                                 Text=""/>
                    </Border>

                    <!-- 密码 -->
                    <TextBlock Text="密码" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <Border x:Name="passwordBorder"
                            Background="{StaticResource GlassGradientBrush}"
                            CornerRadius="{StaticResource RadiusSmall}"
                            BorderBrush="{StaticResource BorderPrimaryBrush}"
                            BorderThickness="1" Margin="0,0,0,28">
                        <Grid>
                            <PasswordBox x:Name="txtPassword"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="14,12"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         FontSize="14"
                                         CaretBrush="{StaticResource PrimaryBrush}"
                                         Password=""/>
                        </Grid>
                    </Border>

                    <!-- 登录按钮 -->
                    <Button x:Name="btnLogin" Content="登 录"
                            Style="{StaticResource BtnGradient}"
                            Height="50" FontSize="17"
                            Click="BtnLogin_Click"/>
                </StackPanel>
            </Border>

            <!-- ═══════ Steam 登录 ═══════ -->
            <Border x:Name="steamCard" Grid.Row="2" Style="{StaticResource GlassCardPremium}"
                    Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
                        <Border Width="24" Height="24" CornerRadius="6"
                                Background="{StaticResource PrimaryBrush}" Opacity="0.12" Margin="0,0,10,0">
                            <TextBlock Text="&#xE777;" FontFamily="Segoe Fluent Icons"
                                       FontSize="14" Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Steam 账号登录" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <Button x:Name="btnSteamLogin" Height="52" FontSize="14"
                            Style="{StaticResource BtnSecondary}"
                            Click="BtnSteamLogin_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE777;" FontFamily="Segoe Fluent Icons"
                                       FontSize="16" Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="使用 Steam 登录" FontFamily="Microsoft YaHei"
                                       FontSize="14" Foreground="{StaticResource PrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ═══════ 底部链接 ═══════ -->
            <StackPanel x:Name="linkSection" Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="注册账号" Style="{StaticResource BtnGhost}"
                        Padding="14,6" FontSize="13" Margin="0,0,16,0"
                        Click="BtnRegister_Click"/>
                <Button Content="忘记密码?" Style="{StaticResource BtnGhost}"
                        Padding="14,6" FontSize="13" Margin="0,0,16,0"
                        Click="BtnForgot_Click"/>
                <Button Content="&#xE774; 服务器" Style="{StaticResource BtnGhost}"
                        Padding="14,6" FontSize="13"
                        Click="BtnServerConfig_Click"/>
            </StackPanel>
            <!-- 法律链接 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button Content="用户协议" Style="{StaticResource BtnLink}" FontSize="11"
                        Click="ViewAgreement_Click"/>
                <TextBlock Text="|" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                           Margin="8,0" VerticalAlignment="Center"/>
                <Button Content="隐私政策" Style="{StaticResource BtnLink}" FontSize="11"
                        Click="ViewPrivacy_Click"/>
                <TextBlock Text="|" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                           Margin="8,0" VerticalAlignment="Center"/>
                <Button Content="平台声明" Style="{StaticResource BtnLink}" FontSize="11"
                        Click="ViewDeclaration_Click"/>
            </StackPanel>

            <!-- 版本号 -->
            <TextBlock Grid.Row="4" Text="v2.0.0 Aurora" FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0,28,0,0"
                       FontFamily="{StaticResource FontMono}"/>
        </Grid>

        <!-- 窗口控制按钮 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,10,12,0" ZIndex="100">
            <Button Content="&#xE921;" Style="{StaticResource WindowControlBtn}"
                    Click="Minimize_Click" FontFamily="Segoe Fluent Icons" Width="36" Height="28"/>
            <Button Content="&#xE8BB;" Style="{StaticResource WindowControlBtn}"
                    Click="Close_Click" FontFamily="Segoe Fluent Icons" Width="36" Height="28"/>
        </StackPanel>
    </Grid>
</Window>
