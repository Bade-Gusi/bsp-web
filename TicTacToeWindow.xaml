<Window x:Class="BeiShuiCS2.TicTacToeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="井字棋"
        Width="420" Height="578"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="井字棋" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    Click="Close_Click"/>
        </Grid>

        <!-- 状态显示 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock x:Name="txtStatus" Text="你的回合 (X)" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="你 (X)" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtPlayerScore" Text="0" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="-" FontSize="20"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="20,0"/>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="电脑 (O)" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtComputerScore" Text="0" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 游戏棋盘 -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="16">
            <Grid x:Name="boardGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 格子 -->
                <Button x:Name="btn0" Grid.Row="0" Grid.Column="0" Style="{StaticResource GridCell}" Tag="0" Click="Cell_Click"/>
                <Button x:Name="btn1" Grid.Row="0" Grid.Column="2" Style="{StaticResource GridCell}" Tag="1" Click="Cell_Click"/>
                <Button x:Name="btn2" Grid.Row="0" Grid.Column="4" Style="{StaticResource GridCell}" Tag="2" Click="Cell_Click"/>
                <Button x:Name="btn3" Grid.Row="2" Grid.Column="0" Style="{StaticResource GridCell}" Tag="3" Click="Cell_Click"/>
                <Button x:Name="btn4" Grid.Row="2" Grid.Column="2" Style="{StaticResource GridCell}" Tag="4" Click="Cell_Click"/>
                <Button x:Name="btn5" Grid.Row="2" Grid.Column="4" Style="{StaticResource GridCell}" Tag="5" Click="Cell_Click"/>
                <Button x:Name="btn6" Grid.Row="4" Grid.Column="0" Style="{StaticResource GridCell}" Tag="6" Click="Cell_Click"/>
                <Button x:Name="btn7" Grid.Row="4" Grid.Column="2" Style="{StaticResource GridCell}" Tag="7" Click="Cell_Click"/>
                <Button x:Name="btn8" Grid.Row="4" Grid.Column="4" Style="{StaticResource GridCell}" Tag="8" Click="Cell_Click"/>

                <!-- 分割线 -->
                <Rectangle Grid.Row="0" Grid.Column="1" Grid.RowSpan="5" Width="2" Fill="{StaticResource BorderPrimaryBrush}"/>
                <Rectangle Grid.Row="0" Grid.Column="3" Grid.RowSpan="5" Width="2" Fill="{StaticResource BorderPrimaryBrush}"/>
                <Rectangle Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Height="2" Fill="{StaticResource BorderPrimaryBrush}"/>
                <Rectangle Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5" Height="2" Fill="{StaticResource BorderPrimaryBrush}"/>
            </Grid>
        </Border>

        <!-- 按钮 -->
        <Button Grid.Row="3" Content="重新开始" Style="{StaticResource BtnPrimary}"
                Height="44" FontSize="14" Margin="0,16,0,0"
                Click="BtnRestart_Click"/>
    </Grid>
</Window>

