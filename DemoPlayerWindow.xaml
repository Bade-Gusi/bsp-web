<Window x:Class="BeiShuiCS2.DemoPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:e="clr-namespace:BeiShuiCS2"
        Title="Demo 播放器" 
        Width="900" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        AllowDrop="True" Drop="Window_Drop" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">


    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,32">
            <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons"
                       FontSize="48" Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="Demo 播放器" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="拖拽 .dem 文件到此处，或点击选择文件"
                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- 拖放区域 -->
        <Border Grid.Row="1"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="2"
                Background="Transparent">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="txtFileName" Text="暂无文件"
                           FontSize="18" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="btnPlay" Content="&#xE768; 播放"
                            Style="{StaticResource BtnPrimary}"
                            Width="140" Height="48" FontSize="16"
                            Click="BtnPlay_Click" IsEnabled="False">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                              Opacity="0.4" Color="{StaticResource PrimaryColor}"/>
                        </Button.Effect>
                    </Button>
                    <Button Content="&#xE8E5; 选择文件"
                            Style="{StaticResource BtnGhost}"
                            Width="140" Height="48" FontSize="14"
                            Margin="16,0,0,0" Click="BtnBrowse_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 关闭按钮 -->
        <Button Grid.Row="2" Content="关闭" Style="{StaticResource BtnGhost}"
                Width="120" Margin="0,22,0,0"
                HorizontalAlignment="Center" Click="Close_Click"/>
    </Grid>
</Window>

