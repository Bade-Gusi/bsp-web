<Window x:Class="BeiShuiCS2.ConfirmExitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="退出背水对战平台"
        Width="420" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">

    <Grid Margin="28" Background="#FF0A1A10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="particleCanvas" IsHitTestVisible="False" Grid.RowSpan="2"/>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Width="56" Height="56" CornerRadius="28"
                    Background="{StaticResource DangerGradientBrush}"
                    HorizontalAlignment="Center" Margin="0,0,0,12">
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons"
                           FontSize="24" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="退出背水对战平台" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="游戏中的对局可能会受到影响" FontSize="13"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"
                       TextWrapping="Wrap"/>
            <TextBlock Text="确定要退出吗？" FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
            <Button Content="取消" Style="{StaticResource BtnNeumorph}"
                    Width="120" Height="48" FontSize="14"
                    Margin="0,0,12,0" Click="Cancel_Click"/>
            <Button Content="确定退出" Style="{StaticResource BtnDanger}"
                    Width="120" Height="48" FontSize="14"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
