<Window x:Class="BeiShuiCS2.PrivateChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="私信" 
        Width="542" Height="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Style="{DynamicResource AuroraWindow}" WindowStyle="None" AllowsTransparency="True">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Height="64" Margin="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                    Background="{StaticResource PrimaryBrush}" Margin="0,0,12,0">
                <TextBlock x:Name="txtFriendInitial" Text="F"
                           Foreground="{StaticResource BgDeepBrush}"
                           FontWeight="Bold" FontSize="16"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="txtFriendName" Text="Friend"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="在线" FontSize="12"
                           Foreground="{StaticResource PrimaryBrush}"/>
            </StackPanel>
            <Button Grid.Column="2" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource WindowControlBtn}"
                    Click="Close_Click"/>
        </Grid>

        <!-- 消息区域 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="24,0,24,16">
            <ScrollViewer x:Name="msgScroll" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="msgPanel" Margin="8">
                    <!-- 动态生成消息气泡 -->
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 输入区域 -->
        <Grid Grid.Row="2" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource BgElevatedBrush}"
                    CornerRadius="{StaticResource RadiusMedium}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                    BorderThickness="1" Margin="0,0,71,0">
                <TextBox x:Name="txtMessage"
                         Background="Transparent" BorderThickness="0"
                         Padding="16,12" Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="14" CaretBrush="{StaticResource PrimaryBrush}"
                         KeyDown="TxtMessage_KeyDown" HorizontalAlignment="Left" Width="421"/>
            </Border>
            <Button Content="&#xE724;" FontFamily="Segoe Fluent Icons"
                    Style="{StaticResource BtnPrimary}" Height="48" FontSize="18"
                    Click="Send_Click" Grid.ColumnSpan="2" Margin="428,0,0,0"/>
        </Grid>
    </Grid>
</Window>
